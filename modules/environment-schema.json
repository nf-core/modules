{
    "$schema": "http://json-schema.org/draft-07/schema",
    "title": "conda environment yaml",
    "description": "Validate the environment.yml file for an nf-core module",
    "type": "object",
    "properties": {
        "channels": {
            "type": "array",
            "items": {
                "type": "string",
                "not": {
                    "const": "default"
                }
            }
        },
        "dependencies": {
            "type": "array",
            "items": {
                "oneOf": [
                    {
                        "type": "string",
                        "pattern": "^.*[^><]=[^><].*$",
                        "$comment": "The above pattern ensures that all packages are pinned to a specific version. This ensures the reproducibility of the environment"
                    },
                    {
                        "type": "string",
                        "pattern": "^pip$",
                        "$comment": "Allow bare pip dependency needed to enable pip installs"
                    },
                    {
                        "type": "object",
                        "properties": {
                            "pip": {
                                "type": "array",
                                "items": {
                                    "type": "string",
                                    "anyOf": [
                                        {
                                            "pattern": "^.*==.*$",
                                            "$comment": "Packages pinned to a specific version"
                                        },
                                        {
                                            "pattern": "^https?://.*$",
                                            "$comment": "Direct URL to a specific package artifact (e.g. wheel file)"
                                        }
                                    ]
                                }
                            }
                        }
                    }
                ]
            }
        }
    },
    "required": ["channels", "dependencies"],
    "not": { "required": ["name"] }
}
