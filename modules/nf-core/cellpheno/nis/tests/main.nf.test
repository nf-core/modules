nextflow_process {

    name "Test Process CELLPHENO_NIS"
    script "../main.nf"
    process "CELLPHENO_NIS"

    tag "modules"
    tag "modules_nfcore"
    tag "cellpheno"
    tag "cellpheno/nis"
    tag "unzip"
    tag "gpu"

    // Real run: needs a CUDA GPU + the published container, so it is tagged `gpu` and
    // skipped on CPU CI. The small real P4 tile ships zipped in nf-core/test-datasets;
    // the ~64 MB TorchScript models are too large for test-datasets and are fetched from
    // a stable Zenodo archive (same approach as numorph/3dunet). Both are extracted with
    // UNZIP (dir inputs). Outputs are asserted by presence rather than md5 (the binary is
    // GPU float non-deterministic).
    test("lightsheet - tile") {

        setup {
            run("UNZIP", alias: "UNZIP_TILE") {
                script "../../../unzip/main.nf"
                process {
                    """
                    input[0] = Channel.of([ [ id:'tile' ],
                        file(params.modules_testdata_base_path + 'imaging/segmentation/cellpheno_nis/cellpheno_nis_tile.zip', checkIfExists: true) ])
                    """
                }
            }
            run("UNZIP", alias: "UNZIP_MODELS") {
                script "../../../unzip/main.nf"
                process {
                    """
                    input[0] = Channel.of([ [ id:'models' ],
                        file('https://zenodo.org/records/21284682/files/cellpheno_nis_models.zip', checkIfExists: true) ])
                    """
                }
            }
        }

        when {
            process {
                """
                input[0] = UNZIP_TILE.out.unzipped_archive
                    .map { meta, d -> [ [ id:'test_brain' ], file(d).listFiles().find { it.isDirectory() } ] }
                input[1] = UNZIP_MODELS.out.unzipped_archive
                    .map { meta, d -> file(d).listFiles().find { it.isDirectory() } }
                """
            }
        }

        then {
            def names = process.out.nis.get(0).get(1).collect { file(it).name }
            assertAll(
                { assert process.success },
                { assert names.size() == 6 },
                { assert names.any { it.endsWith('_instance_center.zip') } },
                { assert names.any { it.endsWith('_instance_coordinate.zip') } },
                { assert names.any { it.endsWith('_instance_volume.zip') } },
                { assert names.any { it.endsWith('_instance_label.zip') } },
                { assert names.any { it.endsWith('_binary_mask.zip') } },
                { assert names.any { it.endsWith('_seg_meta.zip') } },
                { assert process.out.versions }
            )
        }

    }

    test("lightsheet - tile - stub") {

        options "-stub"

        // The stub does not read the tile or the models, so it uses lightweight dummy
        // directories rather than downloading the real test data / Zenodo models.
        when {
            process {
                """
                input[0] = Channel.of([ [ id:'test_brain' ], file("\${projectDir}/modules/nf-core/cellpheno/nis", checkIfExists: true) ])
                input[1] = Channel.of(file("\${projectDir}/modules/nf-core/cellpheno/nis", checkIfExists: true))
                """
            }
        }

        then {
            def names = process.out.nis.get(0).get(1).collect { file(it).name }
            assertAll(
                { assert process.success },
                { assert names.size() == 6 },
                { assert process.out.remap },
                { assert process.out.versions }
            )
        }

    }

}
