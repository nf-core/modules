nextflow_process {

    name "Test Process BWAFASTALIGN_INDEX"
    script "../main.nf"
    process "BWAFASTALIGN_INDEX"

    tag "modules"
    tag "modules_nfcore"
    tag "bwafastalign"
    tag "bwafastalign/index"

    config "./nextflow.config"

    test("BWAFASTALIGN index") {

        when {
            process {
                """
                input[0] = [
                    [id: 'test'],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("BWAFASTALIGN index - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [id: 'test'],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

}
