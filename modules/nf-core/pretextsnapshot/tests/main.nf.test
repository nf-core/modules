nextflow_process {

    name "Test Process PRETEXTSNAPSHOT"
    config "./nextflow.config"
    script "../main.nf"
    process "PRETEXTSNAPSHOT"

    tag "modules"
    tag "modules_nfcore"
    tag "pretext"
    tag "pretextsnapshot"

    test("jaGalFasc40_2 - 'custom order' snapshot pretextmap") {

        when {
            params {
                module_args = '-r 1080'
            }
            process {
                """
                input[0] = [
                    [id:'test'],
                    file(params.modules_testdata_base_path + 'genomics/eukaryotes/galaxea_fascicularis/hic/jaGalFasc40_2.pretext', checkIfExists:true),
                    file(params.modules_testdata_base_path + 'genomics/eukaryotes/galaxea_fascicularis/hic/jaGalFasc40_2_chr_reordering.txt', checkIfExists:true)
                ]
                """
            }
        }
        then {
            assert process.success
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("jaGalFasc40_2 - 'all' snapshot pretextmap") {

        when {
            params {
                module_args = '--sequences "=all" -c 26 -r 1080'
            }
            process {
                """
                input[0] = [
                    [id:'test'],
                    file(params.modules_testdata_base_path + 'genomics/eukaryotes/galaxea_fascicularis/hic/jaGalFasc40_2.pretext', checkIfExists:true),
                    []
                ]
                """
            }
        }
        then {
            assert process.success
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("jaGalFasc40_2 - 'full' snapshot pretextmap") {

        when {
            params {
                module_args = '--sequences "=full" -c 26 -r 1080'
            }
            process {
                """
                input[0] = [
                    [id:'test'],
                    file(params.modules_testdata_base_path + 'genomics/eukaryotes/galaxea_fascicularis/hic/jaGalFasc40_2.pretext', checkIfExists:true),
                    []
                ]
                """
            }
        }
        then {
            assert process.success
            assertAll(
                { assert process.success },
                {
                    assert snapshot(
                        process.out.image.collect { meta, image -> [meta, file(image).name] },
                        process.out.findAll { key, val -> key.startsWith("versions") }
                    ).match()
                }
            )
        }
    }

    test("jaGalFasc40_2 - 'all' snapshot pretextmap - stub") {
        options '-stub'
        when {
            params {
                module_args = '--sequences "=all" -c 26 -r 1080'
            }
            process {
                """
                input[0] = [
                    [id:'test'],
                    file(params.modules_testdata_base_path + 'genomics/eukaryotes/galaxea_fascicularis/hic/jaGalFasc40_2.pretext', checkIfExists:true),
                    []
                ]
                """
            }
        }
        then {
            assert process.success
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

}
