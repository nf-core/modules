nextflow_process {

    name "Test Process MEGAN_RMA2INFO"
    script "../main.nf"
    config "./nextflow.config"
    process "MEGAN_RMA2INFO"

    tag "modules"
    tag "modules_nfcore"
    tag "megan"
    tag "megan/rma2info"

    test("malt - rma") {
        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'delete_me/malt/test.rma6', checkIfExists: true)
                ]
                input[1] = 'true'
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["txt", "megan_summary"])).match() }
            )
        }
    }

    test("malt - rma - stub") {
        options "-stub"
        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'delete_me/malt/test.rma6', checkIfExists: true)
                ]
                input[1] = 'true'
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }
}
