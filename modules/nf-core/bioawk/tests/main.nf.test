
nextflow_process {

    name "Test Process BIOAWK"
    script "../main.nf"
    process "BIOAWK"
    config "./nextflow.config"

    tag "modules"
    tag "modules_nfcore"
    tag "bioawk"

    test("fasta bioawk fasta.gz") {

        when {
            params {
                bioawk_command = "\'{print \">\" \$name ORS length(\$seq)}\'"
                bioawk_prefix = "sample_1"
            }

            process {
                """
                input[0] = [
				    [ id:'test', single_end:false ], // meta map
				    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true)
				]
				input[1] = []
				input[2] = false
				input[3] = "fastx"
				input[4] = "fa.gz"
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("fasta bioawk tsv") {

        when {
            params {
                bioawk_command = "\'{s = toupper(\$seq); g = gsub(/G/, \"\", s); printf \"%s\\t%d\\n\", s, g}\'"
                bioawk_prefix = "telomere_summary"
            }

            process {
                """
                input[0] = [
				    [ id:'test', single_end:false ], // meta map
				    file(params.modules_testdata_base_path + 'generic/telomere/telomeric_motifs.fasta', checkIfExists: true)
				]
				input[1] = []
				input[2] = false
				input[3] = "fastx"
				input[4] = "tsv"
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

}
