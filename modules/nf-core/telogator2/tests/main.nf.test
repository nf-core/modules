// nf-core modules test telogator2
nextflow_process {

    name "Test Process TELOGATOR2"
    script "../main.nf"
    process "TELOGATOR2"

    tag "modules"
    tag "modules_nfcore"
    tag "telogator2"

    test("homo_sapiens - pacbio bam") {
        when {
            process {
                """
                input[0] = [
                    [ id:'test' ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/bam/test.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/bam/test.sorted.bam.bai', checkIfExists: true)
                ]
                input[1] = [ [ id:'genome' ], [] ]
                input[2] = [ [ id:'genome' ], [] ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    process.out.results,
                    process.out.findAll { key, val -> key.startsWith('versions') }
                ).match() }
            )
        }
    }

    test("homo_sapiens - pacbio bam - with reference") {
        when {
            process {
                """
                input[0] = [
                    [ id:'test_ref' ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/bam/test.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/bam/test.sorted.bam.bai', checkIfExists: true)
                ]
                input[1] = [
                    [ id:'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true)
                ]
                input[2] = [
                    [ id:'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.fai', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    process.out.results,
                    process.out.findAll { key, val -> key.startsWith('versions') }
                ).match() }
            )
        }
    }

    test("homo_sapiens - pacbio bam - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'stub' ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/bam/test.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/bam/test.sorted.bam.bai', checkIfExists: true)
                ]
                input[1] = [ [ id:'genome' ], [] ]
                input[2] = [ [ id:'genome' ], [] ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }
}
