
nextflow_process {

    name "Test Process DSHBIO_FILTERGFF3"
    script "../main.nf"
    process "DSHBIO_FILTERGFF3"
    config "./nextflow.config"

    tag "modules"
    tag "modules_nfcore"
    tag "dshbio"
    tag "dshbio/filtergff3"

    test("test-dshbio-filtergff3") {

        when {
            params {
                module_args = '--range MT192765.1:0-1000'
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
				    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gff3.gz', checkIfExists: true)
				]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }

    test("test-dshbio-filtergff3 - stub") {

        options "-stub"

        when {
            params{
                module_args = '--range MT192765.1:0-1000'
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
				    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gff3.gz', checkIfExists: true)
				]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }

}
