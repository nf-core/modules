// nf-core modules test numorph/intensity
nextflow_process {

    name "Test Process NUMORPH_INTENSITY"
    script "../main.nf"
    process "NUMORPH_INTENSITY"

    tag "modules"
    tag "lsmquant"
    tag "modules_nfcore"
    tag "numorph"
    tag "numorph/intensity"
    tag "unzip"

   test("Numorphintensity test") {

        setup {
            run ("UNZIP") {
                script "../../../unzip/main.nf"
                process {
                    """
                    input[0] = Channel.fromList([
                        tuple([ id:'TEST1'],
                        file('https://zenodo.org/records/14916478/files/ctip2_topro.zip'))
                    ])
                """
                }
            }
        }

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = UNZIP.out.unzipped_archive.map { meta, unzipped_archive ->
                    tuple(
                    meta,
                    unzipped_archive,
                    file('https://raw.githubusercontent.com/nf-core/test-datasets/refs/heads/lsmquant/test_data/parameterfiles/params_TEST1_lsmquant.csv'))
                }
                """
            }
        }
        then {
            // Get the directory paths
            def variablesDir = process.out.variables.get(0).get(1)
            def samplesDir = process.out.samples.get(0).get(1)

            // Use getAllFilesFromDir to get relative file paths
            def variablesFiles = getAllFilesFromDir(variablesDir, relative: true, includeDir: false)
            def samplesFiles = getAllFilesFromDir(samplesDir, relative: true, includeDir: false)
            assertAll (
                { assert process.success },
                { assert file(process.out.NM_variable.get(0).get(1)).exists() : "NM_variables.mat file does not exist" },
                { assert variablesFiles.size() == 3 },
                { assert samplesFiles.size() == 14 },
                { assert snapshot(
                    variablesFiles,
                    samplesFiles,
                    process.out.versions
                ).match()}
            )

        }
    }

    test("Numorphintensity stub test") {

        options '-stub'

        when {
            process {
                """
                input[0] = Channel.fromList([
                    tuple([ id:'TEST1'],
                    file('https://zenodo.org/records/14916478/files/ctip2_topro.zip'),
                    file(params.pipelines_testdata_base_path + '/test_data/parameterfiles/params_TEST1_lsmquant.csv'))
                    ])
                """
            }
        }
        then {
            assert process.success              // Check process completed successfully
            assert snapshot(process.out).match() // Validate outputs match expected snapshot
        }
    }

}
