// nf-core modules test numorph/resample
nextflow_process {

    name "Test Process NUMORPH_RESAMPLE"
    script "../main.nf"
    process "NUMORPH_RESAMPLE"

    tag "modules"
    tag "lsmquant"
    tag "modules_nfcore"
    tag "numorph"
    tag "numorph/resample"
    tag "unzip"

    // only stub test because the test data is very larger in order to run the process
    test("Numorph resample stub test") {
        options '-stub'
        setup {
            run ("UNZIP") {
                script "../../../unzip/main.nf"
                process {
                    """
                    input[0] = Channel.fromList([
                        tuple([ id:'stitched'],
                        file('https://raw.githubusercontent.com/nf-core/test-datasets/refs/heads/lsmquant/test_data/unet_test_images.zip'))
                    ])
                """
                }
            }

        }
        when {
            params {
                outdir = "$outputDir"
            }
            process {
               """
                input[0] = UNZIP.out.unzipped_archive.map { meta, unzipped_archive ->
                    tuple(
                    meta,
                    unzipped_archive,
                    file('https://raw.githubusercontent.com/nf-core/test-datasets/refs/heads/lsmquant/test_data/parameterfiles/params_TEST1_lsmquant.csv'))
                }
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
