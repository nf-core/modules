nextflow_process {

    name "Test Process BEDTOOLS_FLANK"
    script "../main.nf"
    process "BEDTOOLS_FLANK"

    tag "modules"
    tag "modules_nfcore"
    tag "bedtools"
    tag "bedtools/flank"

    config "./nextflow.config"

   test("sarscov2 - [bed], [sizes]") {

        when {
            process {
                """
                input[0] = [ [ id:'test'],
				    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/bed/test.bed', checkIfExists: true)
				]
				input[1] = file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.sizes', checkIfExists: true)
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("sarscov2 - [bed], [sizes] - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [ [ id:'test'],
				    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/bed/test.bed', checkIfExists: true)
				]
				input[1] = file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.sizes', checkIfExists: true)
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

}
