nextflow_process {

    name "Test Process RPBP_BUILDCONFIG"
    script "../main.nf"
    process "RPBP_BUILDCONFIG"

    tag "modules"
    tag "modules_nfcore"
    tag "rpbp"
    tag "rpbp/buildconfig"

    test("homo_sapiens chr20 - render config") {

        when {
            process {
                """
                input[0] = [
                    [ id:'reference' ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/riboseq_expression/Homo_sapiens.GRCh38.dna.chromosome.20.fa.gz", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/riboseq_expression/Homo_sapiens.GRCh38.111_chr20.gtf", checkIfExists: true)
                ]
                input[1] = 'reference'
                input[2] = ''
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    path(process.out.config[0][1]).readLines(),
                    process.out.findAll { key, val -> key.startsWith('versions') }
                ).match() }
            )
        }
    }

    test("homo_sapiens chr20 - render config - stub") {

        options '-stub'

        when {
            process {
                """
                input[0] = [
                    [ id:'reference' ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/riboseq_expression/Homo_sapiens.GRCh38.dna.chromosome.20.fa.gz", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/riboseq_expression/Homo_sapiens.GRCh38.111_chr20.gtf", checkIfExists: true)
                ]
                input[1] = 'reference'
                input[2] = ''
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
