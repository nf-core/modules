                ]
                input[1] = 'openms'
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

    test("sdrf - maxquant - PXD009752") {

        when {
            params {
                module_args = '-f PXD009752.sdrf.tsv -r .'
            }
            process {
                """
                input[0] = [
                    [ id: 'PXD009752' ],
