
nextflow_process {

    name "Test Process SICKLE"
    script "../main.nf"
    process "SICKLE"
    config "./nextflow.config"

    tag "modules"
    tag "modules_nfcore"
    tag "sickle"

    test("test-sickle-single-end") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test', single_end:true], // meta map
				    [ file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true) ],
				    "sanger"
				]

                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["log"])).match() }
            )
        }
    }

    test("test-sickle-paired-end") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test', single_end:false, qual:'sanger' ], // meta map
				    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
				        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ],
				    "sanger"
				]

                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["log"])).match() }
            )
        }
    }

    test("test-sickle-stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test', single_end:true], // meta map
				    [ file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true) ],
				    "sanger"
				]

                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["log"])).match() }
            )
        }
    }

}
