nextflow_process {

    name "Test Process UPDHMM_VCFCHECK"
    script "../main.nf"
    process "UPDHMM_VCFCHECK"
    
    tag "modules"
    tag "modules_nfcore"
    tag "bcftools/view"
    tag "updhmm"
    tag "updhmm/vcfcheck"

    setup {
        run("BCFTOOLS_VIEW") {
            script "../../../../nf-core/bcftools/view/main.nf"
            process {
                """
                input[0] = Channel.of([
                    [ id:'test_trio' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/vcf/ped/justhusky_minimal.vcf.gz', checkIfExists: true),
                    []
                ])
                input[1] = []  // regions
                input[2] = []  // targets
                input[3] = []  // samples
                """
            }
        }
    }

    test("trio vcf") {
    
        config './vcfcheck.config'
    
        when {
            process {
                """
                input[0] = BCFTOOLS_VIEW.out.vcf.map { meta, vcf ->
                    [
                        [ id:'test_trio',
                          proband_id: 'hugelymodelbat',
                          mother_id: 'slowlycivilbuck',
                          father_id: 'earlycasualcaiman' 
                        ],
                        vcf,
                        []
                    ]
                }
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                { assert process.out.processed_vcf },
                { assert process.out.session_info },
                { assert process.out.versions_updhmm },
                { assert process.out.versions_variantannotation },
                { assert process.out.versions_rbase },
                { assert path(process.out.processed_vcf.get(0).get(1)).exists() },
                { assert path(process.out.session_info.get(0).get(1)).exists() }
            )
        }
    }

    test("trio vcf - stub") {

        options "-stub"
        config './vcfcheck.config'

        when {
            process {
                """
                input[0] = [
                    [ id:'test_trio',
                      proband_id: 'hugelymodelbat',
                      mother_id: 'slowlycivilbuck',
                      father_id: 'earlycasualcaiman' 
                    ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/vcf/ped/justhusky_minimal.vcf.gz', checkIfExists: true),
                    []
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                { assert path(process.out.processed_vcf.get(0).get(1)).exists() },
                { assert path(process.out.session_info.get(0).get(1)).exists() }
            )
        }
    }
}