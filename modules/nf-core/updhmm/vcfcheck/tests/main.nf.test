nextflow_process {

    name "Test Process UPDHMM_VCFCHECK"
    script "../main.nf"
    process "UPDHMM_VCFCHECK"

    tag "modules"
    tag "modules_nfcore"
    tag "bcftools/view"
    tag "updhmm"
    tag "updhmm/vcfcheck"

    setup {
        run("BCFTOOLS_VIEW") {
            script "../../../../nf-core/bcftools/view/main.nf"
            process {
                """
                input[0] = Channel.of([
                    [ id:'test_trio' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/vcf/ped/justhusky_minimal.vcf.gz', checkIfExists: true),
                    []
                ])
                input[1] = []  // regions
                input[2] = []  // targets
                input[3] = []  // samples
                """
            }
        }
    }

    test("trio vcf") {

        config './nextflow.config'

        when {
            process {
                """
                input[0] = BCFTOOLS_VIEW.out.vcf.map { meta, vcf ->
                    [
                        [ id:'test_trio',
                          proband_id: 'hugelymodelbat',
                          mother_id: 'slowlycivilbuck',
                          father_id: 'earlycasualcaiman'
                        ],
                        vcf,
                        []
                    ]
                }
                """
            }
        }

        then {
            def session_text = path(process.out.session_info[0][1]).getText()
            assertAll(
                { assert process.success },
                { assert session_text.contains("R version") },
                { assert session_text.contains("UPDhmm_1.6.0") },
                { assert session_text.contains("VariantAnnotation_1.52.0") },
                { assert snapshot(
                    process.out.processed_rds,
                    process.out.versions
                ).match() }
            )
        }
    }

    test("trio vcf - stub") {

        options "-stub"
        config './nextflow.config'

        when {
            process {
                """
                input[0] = [
                    [ id:'test_trio',
                      proband_id: 'hugelymodelbat',
                      mother_id: 'slowlycivilbuck',
                      father_id: 'earlycasualcaiman'
                    ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/vcf/ped/justhusky_minimal.vcf.gz', checkIfExists: true),
                    []
                ]
                """
            }
        }

        then {
            def session_text = path(process.out.session_info[0][1]).getText()
            assertAll(
                { assert process.success },
                { assert snapshot(
                    process.out.processed_rds,
                    process.out.session_info,
                    process.out.versions
                ).match() }
            )
        }
    }
}
