process {

    withName: STAR_GENOMEGENERATE {
        ext.args = '--genomeSAindexNbases 9'
    }

    withName: STAR_ALIGN {
        ext.args = { "--readFilesCommand zcat --outSAMtype BAM SortedByCoordinate --outWigType bedGraph --outWigStrand Unstranded --outSAMattrRGline 'ID:${meta.id}' 'SM:${meta.id}' 'PL:illumina'" }
    }

}
