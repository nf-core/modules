nextflow_process {

    name "Test Process CENTRIFUGER_BUILD"
    script "../main.nf"
    process "CENTRIFUGER_BUILD"

    tag "modules"
    tag "modules_nfcore"
    tag "centrifuger"
    tag "centrifuger/build"

    test("sarscov2 - fasta") {
        when {
            process {
                """
                input[0] = [[ id:'test' ],file(params.modules_testdata_base_path + "genomics/sarscov2/genome/genome.fasta", checkIfExists: true)]
                input[1] = file(params.modules_testdata_base_path + "genomics/sarscov2/metagenome/nodes.dmp", checkIfExists: true)
                input[2] = file(params.modules_testdata_base_path + "genomics/sarscov2/metagenome/names.dmp", checkIfExists: true)
                input[3] = file(params.modules_testdata_base_path + "genomics/sarscov2/metagenome/seqid2taxid.map", checkIfExists: true)
                input[4] = []
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out.versions_centrifuger).match() }
            )
        }

    }

   test("sarscov2 - fasta -stub") {
        options "-stub"

        when {
            process {
                """
                input[0] = [[ id:'test' ],file(params.modules_testdata_base_path + "genomics/sarscov2/genome/genome.fasta", checkIfExists: true)]
                input[1] = file(params.modules_testdata_base_path + "genomics/sarscov2/metagenome/nodes.dmp", checkIfExists: true)
                input[2] = file(params.modules_testdata_base_path + "genomics/sarscov2/metagenome/names.dmp", checkIfExists: true)
                input[3] = file(params.modules_testdata_base_path + "genomics/sarscov2/metagenome/seqid2taxid.map", checkIfExists: true)
                input[4] = []
                """
            }
        }

    then {
        assertAll(
        { assert process.success },
        { assert snapshot(process.out.versions_centrifuger).match() }
    )
        }

    }

    test("sarscov2 - fasta with reference list") {

        when {
            process {
                """
                input[0] = [[ id:'test' ],file(params.modules_testdata_base_path + "genomics/sarscov2/genome/genome.fasta", checkIfExists: true)]
                input[1] = file(params.modules_testdata_base_path + "genomics/sarscov2/metagenome/nodes.dmp", checkIfExists: true)
                input[2] = file(params.modules_testdata_base_path + "genomics/sarscov2/metagenome/names.dmp", checkIfExists: true)
                input[3] = []
                input[4] = Channel.of("genome.fasta\\t0.1").collectFile(name: 'refs_list.txt', newLine:false).first()
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out.versions_centrifuger).match() }
            )
        }

    }

   test("sarscov2 - fasta with reference list-stub") {
        options "-stub"

        when {
            process {
                """
                input[0] = [[ id:'test' ], file(params.modules_testdata_base_path + "genomics/sarscov2/genome/genome.fasta", checkIfExists: true)]
                input[1] = file(params.modules_testdata_base_path + "genomics/sarscov2/metagenome/nodes.dmp", checkIfExists: true)
                input[2] = file(params.modules_testdata_base_path + "genomics/sarscov2/metagenome/names.dmp", checkIfExists: true)
                input[3] = []
                input[4] = Channel.of("genome.fasta\\t0.1").collectFile(name: 'refs_list.txt', newLine:false).first()
                """
            }
        }
    then {
        assertAll(
        { assert process.success },
        { assert snapshot(process.out.versions_centrifuger).match() }
    )
        }

    }


}
