// nf-core modules test epic2/epic2
nextflow_process {

    name "Test Process EPIC2_EPIC2"
    script "../main.nf"
    process "EPIC2_EPIC2"

    tag "modules"
    tag "modules_nfcore"
    tag "epic2"
    tag "epic2/epic2"

    config "./nextflow.config"

    test("homo_sapiens - epic2 - ipbam,controlbam - ext.args genome") {

        when {
            params {
                module_args = '--genome hg19'
            }

            process {
                """
                input[0] = [
                    [ id:'test', single_end:false ], // meta map
                    [ file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test.paired_end.name.sorted.bam', checkIfExists: true) ],
                    [ file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test2.paired_end.name.sorted.bam', checkIfExists: true) ]
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }

    test("homo_sapiens - epic2 - ipbam - ext.args genome") {

        when {
            params {
                module_args = '--genome hg19'
            }

            process {
                """
                input[0] = [
                    [ id:'test', single_end:false ], // meta map
                    [ file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test.paired_end.name.sorted.bam', checkIfExists: true) ],
                    []
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }

    test("homo_sapiens - epic2 - ipbam,controlbam - ext.args genome - stub") {

        options "-stub"

        when {
            params {
                module_args = '--genome hg19'
            }

            process {
                """
                input[0] = [
                    [ id:'test', single_end:false ], // meta map
                    [ file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test.paired_end.name.sorted.bam', checkIfExists: true) ],
                    [ file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test2.paired_end.name.sorted.bam', checkIfExists: true) ]
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }

    test("homo_sapiens - epic2 - ipbam - ext.args genome - stub") {

        options "-stub"

        when {
            params {
                module_args = '--genome hg19'
            }

            process {
                """
                input[0] = [
                    [ id:'test', single_end:false ], // meta map
                    [ file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test.paired_end.name.sorted.bam', checkIfExists: true) ],
                    []
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }
}
