nextflow_process {

    name "Test nf-core LDAK_ADDGRMS module"
    script "../main.nf"
    process "LDAK_ADDGRMS"

    tag "modules"
    tag "modules_nfcore"
    tag "ldak"
    tag "ldak/calckins"
    tag "ldak/addgrms"

    setup {
        run("LDAK_CALCKINS", alias: "LDAK_CALCKINS_CHR01") {
            script "../../calckins/main.nf"
            process {
                """
                input[0] = [
                    [ id: "chr01.vcf" ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bed", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bim", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.fam", checkIfExists: true)
                ]
                input[1] = [[:], []]
                input[2] = "-0.25"
                """
            }
        }

        run("LDAK_CALCKINS", alias: "LDAK_CALCKINS_CHR02") {
            script "../../calckins/main.nf"
            process {
                """
                input[0] = [
                    [ id: "chr02.vcf" ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bed", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bim", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.fam", checkIfExists: true)
                ]
                input[1] = [[:], []]
                input[2] = "-0.25"
                """
            }
        }
    }

    test("homo_sapiens popgen - combine GRMs from setup-generated components") {

        when {
            process {
                """
                def mgrm = file("${outputDir}/ldak_test.mgrm")
                mgrm.text = "chr01.vcf\\nchr02.vcf\\n"
                mgrmFile = Channel.value(mgrm)

                groupedGrms = LDAK_CALCKINS_CHR01.out.ldak_grm
                    .mix(LDAK_CALCKINS_CHR02.out.ldak_grm)
                    .map { meta, grmBin, grmId, grmDetails, grmAdjust ->
                        tuple("ldak_grm", grmBin, grmId, grmDetails, grmAdjust)
                    }
                    .groupTuple(by: 0)

                input[0] = groupedGrms.combine(mgrmFile).map { groupId, bins, ids, details, adjusts, mgrmPath ->
                    tuple([ id: groupId ], mgrmPath, bins + ids + details + adjusts)
                }
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }

    test("homo_sapiens popgen - stub") {

        options "-stub"

        when {
            process {
                """
                def mgrm = file("${outputDir}/ldak_test.mgrm")
                mgrm.text = "chr01.vcf\\nchr02.vcf\\n"
                mgrmFile = Channel.value(mgrm)

                groupedGrms = LDAK_CALCKINS_CHR01.out.ldak_grm
                    .mix(LDAK_CALCKINS_CHR02.out.ldak_grm)
                    .map { meta, grmBin, grmId, grmDetails, grmAdjust ->
                        tuple("ldak_grm_stub", grmBin, grmId, grmDetails, grmAdjust)
                    }
                    .groupTuple(by: 0)

                input[0] = groupedGrms.combine(mgrmFile).map { groupId, bins, ids, details, adjusts, mgrmPath ->
                    tuple([ id: groupId ], mgrmPath, bins + ids + details + adjusts)
                }
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }
}
