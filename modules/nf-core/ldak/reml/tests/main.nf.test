nextflow_process {

    name "Test nf-core LDAK_REML module"
    script "../main.nf"
    process "LDAK_REML"

    tag "modules"
    tag "modules_nfcore"
    tag "ldak"
    tag "ldak/calckins"
    tag "ldak/addgrms"
    tag "ldak/filterrelatedness"
    tag "ldak/reml"

    setup {
        run("LDAK_CALCKINS", alias: "LDAK_CALCKINS_CHR21") {
            script "../../calckins/main.nf"
            process {
                """
                input[0] = [
                    [ id: "plink_simulated_chr21" ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bed", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bim", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.fam", checkIfExists: true)
                ]
                input[1] = [[:], []]
                input[2] = "-0.25"
                """
            }
        }

        run("LDAK_CALCKINS", alias: "LDAK_CALCKINS_CHR22") {
            script "../../calckins/main.nf"
            process {
                """
                input[0] = [
                    [ id: "plink_simulated_chr22" ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bed", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bim", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.fam", checkIfExists: true)
                ]
                input[1] = [[:], []]
                input[2] = "-0.25"
                """
            }
        }

        run("LDAK_ADDGRMS") {
            script "../../addgrms/main.nf"
            process {
                """
                mgrm = file("${outputDir}/ldak_test.mgrm")
                mgrm.text = "plink_simulated_chr21\\nplink_simulated_chr22\\n"
                mgrm_file = Channel.value(mgrm)

                grouped_grms = LDAK_CALCKINS_CHR21.out.ldak_grm
                    .mix(LDAK_CALCKINS_CHR22.out.ldak_grm)
                    .map { meta, grm_bin, grm_id, grm_details, grm_adjust ->
                        tuple("ldak_grm", grm_bin, grm_id, grm_details, grm_adjust)
                    }
                    .groupTuple(by: 0)

                input[0] = grouped_grms.combine(mgrm_file).map { group_id, bins, ids, details, adjusts, mgrm_path ->
                    tuple([ id: group_id ], mgrm_path, bins + ids + details + adjusts)
                }
                """
            }
        }

        run("LDAK_FILTERRELATEDNESS") {
            script "../../filterrelatedness/main.nf"
            process {
                """
                input[0] = LDAK_ADDGRMS.out.combined_grm.map { meta, grm_bin, grm_id, grm_details, grm_adjust ->
                    tuple([ id: "ldak_grm_subset" ], grm_bin, grm_id, grm_details, grm_adjust)
                }
                """
            }
        }
    }

    test("homo_sapiens popgen - quantitative with explicit mpheno 1") {

        when {
            process {
                """
                input[0] = [
                    [ id: "reml_quantitative" ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated_quantitative_phenoname.phe", checkIfExists: true),
                    1,
                    []
                ]
                input[1] = LDAK_ADDGRMS.out.combined_grm
                input[2] = LDAK_FILTERRELATEDNESS.out.filtered_list.map { meta, keep_file, lose_file, maxrel_file ->
                    tuple([ id: "keep" ], keep_file)
                }
                input[3] = [[:], []]
                input[4] = [[:], []]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.reml_results.size() == 1 },
                { assert process.out.versions_ldak6.size() == 1 },
                {
                    def remlTuple = process.out.reml_results.get(0)
                    def outMeta = remlTuple.get(0)
                    def remlFile = path(remlTuple.get(1))
                    def commandText = remlFile.parent.resolve(".command.sh").text
                    assert outMeta.id == "reml_quantitative"
                    assert remlFile.fileName.toString() == "reml_quantitative.reml"
                    assert !commandText.contains("--prevalence ")
                    assert commandText.contains("--mpheno 1")
                },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }

    test("homo_sapiens popgen - binary with fallback mpheno 1") {

        when {
            process {
                """
                input[0] = [
                    [ id: "reml_binary" ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated_binary_phenoname.phe", checkIfExists: true),
                    [],
                    0.12
                ]
                input[1] = LDAK_ADDGRMS.out.combined_grm
                input[2] = LDAK_FILTERRELATEDNESS.out.filtered_list.map { meta, keep_file, lose_file, maxrel_file ->
                    tuple([ id: "keep" ], keep_file)
                }
                input[3] = [[:], []]
                input[4] = [[:], []]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.reml_results.size() == 1 },
                { assert process.out.versions_ldak6.size() == 1 },
                {
                    def remlTuple = process.out.reml_results.get(0)
                    def outMeta = remlTuple.get(0)
                    def remlFile = path(remlTuple.get(1))
                    def commandText = remlFile.parent.resolve(".command.sh").text
                    assert outMeta.id == "reml_binary"
                    assert remlFile.fileName.toString() == "reml_binary.reml"
                    assert remlFile.text.contains("Num_Kinships")
                    assert commandText.contains("--prevalence 0.12")
                    assert commandText.contains("--mpheno 1")
                },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }

    test("homo_sapiens popgen - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id: "reml_stub" ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated_binary_phenoname.phe", checkIfExists: true),
                    1,
                    0.12
                ]
                input[1] = LDAK_ADDGRMS.out.combined_grm
                input[2] = LDAK_FILTERRELATEDNESS.out.filtered_list.map { meta, keep_file, lose_file, maxrel_file ->
                    tuple([ id: "keep" ], keep_file)
                }
                input[3] = [[:], []]
                input[4] = [[:], []]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }
}
