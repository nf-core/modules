nextflow_process {

    name "Test Process CALC_INFLATION"
    script "../main.nf"
    process "CALC_INFLATION"

    tag "modules"
    tag "modules_nfcore"
    tag "ldak"
    tag "ldak/calc-kins"
    tag "ldak/add-grms"
    tag "ldak/filter-relatedness"
    tag "ldak/reml"
    tag "ldak/calc-inflation"

    setup {
        run("CALC_KINS", alias: "CALC_KINS_CHR21") {
            script "../../calc-kins/main.nf"
            process {
                """
                input[0] = [
                    [ id: "plink_simulated_chr21" ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bed", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bim", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.fam", checkIfExists: true)
                ]
                input[1] = "-0.25"
                input[2] = [[:], []]
                """
            }
        }

        run("CALC_KINS", alias: "CALC_KINS_CHR22") {
            script "../../calc-kins/main.nf"
            process {
                """
                input[0] = [
                    [ id: "plink_simulated_chr22" ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bed", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bim", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.fam", checkIfExists: true)
                ]
                input[1] = "-0.25"
                input[2] = [[:], []]
                """
            }
        }

        run("LDAK_ADD_GRMS") {
            script "../../add-grms/main.nf"
            process {
                """
                mgrm_file = Channel
                    .of("plink_simulated_chr21", "plink_simulated_chr22")
                    .collectFile(name: "ldak_test.mgrm", newLine: true)

                grouped_grms = CALC_KINS_CHR21.out.ldak_grm
                    .mix(CALC_KINS_CHR22.out.ldak_grm)
                    .map { meta, grm_bin, grm_id, grm_details, grm_adjust ->
                        tuple("ldak_grm", grm_bin, grm_id, grm_details, grm_adjust)
                    }
                    .groupTuple(by: 0)

                input[0] = grouped_grms.combine(mgrm_file).map { group_id, bins, ids, details, adjusts, mgrm ->
                    tuple([ id: group_id ], mgrm, bins + ids + details + adjusts)
                }
                """
            }
        }

        run("LDAK_FILTER_RELATEDNESS") {
            script "../../filter-relatedness/main.nf"
            process {
                """
                input[0] = LDAK_ADD_GRMS.out.combined_grm.map { meta, grm_bin, grm_id, grm_details, grm_adjust ->
                    tuple([ id: "ldak_grm_subset", grm_prefix: "ldak_grm" ], grm_bin, grm_id, grm_details, grm_adjust)
                }
                """
            }
        }

        run("LDAK_REML", alias: "LDAK_REML_FULL") {
            script "../../reml/main.nf"
            process {
                """
                input[0] = [
                    [ id: "reml_full_ldak_grm", is_binary: false ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated_quantitative_phenoname.phe", checkIfExists: true)
                ]
                input[1] = LDAK_ADD_GRMS.out.combined_grm.map { meta, grm_bin, grm_id, grm_details, grm_adjust ->
                    tuple([ id: "ldak_grm", grm_prefix: "ldak_grm" ], grm_bin, grm_id, grm_details, grm_adjust)
                }
                input[2] = LDAK_FILTER_RELATEDNESS.out.filtered_list.map { meta, keep_file, lose_file, maxrel_file ->
                    tuple([ id: "keep" ], keep_file)
                }
                input[3] = [[:], []]
                input[4] = [[:], []]
                input[5] = 1
                """
            }
        }

    }

    test("homo_sapiens popgen - inflation report from setup-generated REML outputs fixture-free") {

        when {
            process {
                """
                input[0] = LDAK_REML_FULL.out.reml_results.map { meta, reml_file ->
                    quarter1 = file(meta.id + ".quarter1.reml")
                    quarter1.text = file(reml_file).text
                    quarter2 = file(meta.id + ".quarter2.reml")
                    quarter2.text = file(reml_file).text
                    tuple([ id: "inflation_Y1" ], reml_file, [quarter1, quarter2])
                }
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.inflation_results.size() == 1 },
                {
                    def resultFile = path(process.out.inflation_results.get(0).get(1))
                    assert resultFile.fileName.toString() == "inflation_Y1.txt"
                    assert resultFile.text.contains("LDAK Inflation Analysis Results")
                },
                {
                    def stableInflation = process.out.inflation_results.collect { resultTuple ->
                        [resultTuple[0], path(resultTuple[1]).readLines()]
                    }
                    assert snapshot(
                        stableInflation,
                        process.out.findAll { key, val -> key.startsWith("versions") }
                    ).match()
                }
            )
        }
    }

    test("homo_sapiens popgen - inflation stub fixture-free") {

        options "-stub"

        when {
            process {
                """
                input[0] = LDAK_REML_FULL.out.reml_results.map { meta, reml_file ->
                    quarter1 = file(meta.id + ".stub.quarter1.reml")
                    quarter1.text = file(reml_file).text
                    quarter2 = file(meta.id + ".stub.quarter2.reml")
                    quarter2.text = file(reml_file).text
                    tuple([ id: "inflation_Y1_stub" ], reml_file, [quarter1, quarter2])
                }
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
