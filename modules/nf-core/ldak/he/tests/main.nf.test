nextflow_process {

    name "Test nf-core LDAK_HE module"
    script "../main.nf"
    process "LDAK_HE"

    tag "modules"
    tag "modules_nfcore"
    tag "ldak"
    tag "ldak/calckins"
    tag "ldak/addgrms"
    tag "ldak/adjustgrm"
    tag "ldak/he"

    setup {
        run("LDAK_CALCKINS", alias: "LDAK_CALCKINS_CHR21") {
            script "../../calckins/main.nf"
            process {
                """
                input[0] = [
                    [ id: "plink_simulated_chr21" ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bed", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bim", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.fam", checkIfExists: true)
                ]
                input[1] = [[:], []]
                input[2] = "-0.25"
                """
            }
        }

        run("LDAK_CALCKINS", alias: "LDAK_CALCKINS_CHR22") {
            script "../../calckins/main.nf"
            process {
                """
                input[0] = [
                    [ id: "plink_simulated_chr22" ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bed", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bim", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.fam", checkIfExists: true)
                ]
                input[1] = [[:], []]
                input[2] = "-0.25"
                """
            }
        }

        run("LDAK_ADDGRMS") {
            script "../../addgrms/main.nf"
            process {
                """
                mgrm = file("${outputDir}/ldak_test.mgrm")
                mgrm.text = "plink_simulated_chr21\\nplink_simulated_chr22\\n"
                mgrm_file = Channel.value(mgrm)

                grouped_grms = LDAK_CALCKINS_CHR21.out.ldak_grm
                    .mix(LDAK_CALCKINS_CHR22.out.ldak_grm)
                    .map { meta, grm_bin, grm_id, grm_details, grm_adjust ->
                        tuple("ldak_grm", grm_bin, grm_id, grm_details, grm_adjust)
                    }
                    .groupTuple(by: 0)

                input[0] = grouped_grms.combine(mgrm_file).map { group_id, bins, ids, details, adjusts, mgrm_path ->
                    tuple([ id: group_id ], mgrm_path, bins + ids + details + adjusts)
                }
                """
            }
        }

        run("LDAK_ADJUSTGRM") {
            script "../../adjustgrm/main.nf"
            process {
                """
                input[0] = LDAK_ADDGRMS.out.combined_grm.map { meta, grm_bin, grm_id, grm_details, grm_adjust ->
                    tuple([ id: "ldak_grm_adj" ], grm_bin, grm_id, grm_details, grm_adjust)
                }
                input[1] = [
                    [ id: "plink_simulated_quantitative_phenoname" ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated_quantitative_phenoname.phe", checkIfExists: true),
                    1
                ]
                input[2] = [
                    [ id: "covariates" ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated_covariates.txt", checkIfExists: true)
                ]
                """
            }
        }
    }

    test("homo_sapiens popgen - explicit mpheno 1") {

        when {
            process {
                """
                input[0] = [
                    [ id: "he_quantitative" ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated_quantitative_phenoname.phe", checkIfExists: true),
                    1
                ]
                input[1] = LDAK_ADJUSTGRM.out.adjusted_grm.map { meta, meta2, grm_bin, grm_id, grm_details, grm_adjust, grm_root ->
                    tuple([ id: meta.id ], grm_bin, grm_id, grm_details, grm_adjust, grm_root)
                }
                input[2] = [[:], []]
                input[3] = [[:], []]
                input[4] = [[:], []]
                input[5] = ''
                input[6] = 0
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.he_results.size() == 1 },
                { assert process.out.versions_ldak6.size() == 1 },
                {
                    def heTuple = process.out.he_results.get(0)
                    def heFile = path(heTuple.get(1))
                    def commandText = heFile.parent.resolve(".command.sh").text
                    assert heTuple.get(0).id == "he_quantitative"
                    assert heFile.fileName.toString() == "he_quantitative.he"
                    assert heFile.text.contains("Num_Kinships")
                    assert commandText.contains("--mpheno 1")
                },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys: ["he_results", "cross"])).match() }
            )
        }
    }

    test("homo_sapiens popgen - fallback mpheno 1") {

        when {
            process {
                """
                input[0] = [
                    [ id: "he_quantitative_fallback" ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated_quantitative_phenoname.phe", checkIfExists: true),
                    []
                ]
                input[1] = LDAK_ADJUSTGRM.out.adjusted_grm.map { meta, meta2, grm_bin, grm_id, grm_details, grm_adjust, grm_root ->
                    tuple([ id: meta.id ], grm_bin, grm_id, grm_details, grm_adjust, grm_root)
                }
                input[2] = [[:], []]
                input[3] = [[:], []]
                input[4] = [[:], []]
                input[5] = ''
                input[6] = 0
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.he_results.size() == 1 },
                { assert process.out.versions_ldak6.size() == 1 },
                {
                    def heTuple = process.out.he_results.get(0)
                    def heFile = path(heTuple.get(1))
                    def commandText = heFile.parent.resolve(".command.sh").text
                    assert heTuple.get(0).id == "he_quantitative_fallback"
                    assert heFile.fileName.toString() == "he_quantitative_fallback.he"
                    assert heFile.text.contains("Num_Kinships")
                    assert commandText.contains("--mpheno 1")
                },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys: ["he_results", "cross"])).match() }
            )
        }
    }

    test("homo_sapiens popgen - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id: "he_stub" ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated_quantitative_phenoname.phe", checkIfExists: true),
                    1
                ]
                input[1] = LDAK_ADJUSTGRM.out.adjusted_grm.map { meta, meta2, grm_bin, grm_id, grm_details, grm_adjust, grm_root ->
                    tuple([ id: meta.id ], grm_bin, grm_id, grm_details, grm_adjust, grm_root)
                }
                input[2] = [[:], []]
                input[3] = [[:], []]
                input[4] = [[:], []]
                input[5] = ''
                input[6] = 0
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys: ["he_results", "cross"])).match() }
            )
        }
    }
}
