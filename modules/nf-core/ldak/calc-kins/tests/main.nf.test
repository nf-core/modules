nextflow_process {

    name "Test Process CALC_KINS"
    script "../main.nf"
    process "CALC_KINS"

    tag "modules"
    tag "modules_nfcore"
    tag "ldak"
    tag "ldak/thin-predictors"
    tag "ldak/create_thin_weights"
    tag "ldak/calc-kins"

    setup {
        run("THIN_PREDICTORS") {
            script "../../thin-predictors/main.nf"
            process {
                """
                input[0] = [
                    [ id: "plink_simulated" ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bed", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bim", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.fam", checkIfExists: true)
                ]
                """
            }
        }

        run("CREATE_THIN_WEIGHTS") {
            script "../../create_thin_weights/main.nf"
            process {
                """
                input[0] = THIN_PREDICTORS.out.thin_predictors
                """
            }
        }
    }

    test("homo_sapiens popgen - unweighted kinship") {

        when {
            process {
                """
                input[0] = [
                    [ id: "plink_simulated_unweighted" ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bed", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bim", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.fam", checkIfExists: true)
                ]
                input[1] = "-0.25"
                input[2] = [[:], []]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.ldak_grm.size() == 1 },
                {
                    def grmTuple = process.out.ldak_grm.get(0)
                    def grmBin = path(grmTuple.get(1))
                    assert grmBin.fileName.toString() == "plink_simulated_unweighted.grm.bin"
                    assert path(grmTuple.get(2)).fileName.toString() == "plink_simulated_unweighted.grm.id"
                    def commandText = grmBin.parent.resolve(".command.sh").text
                    assert commandText.contains("--power -0.25")
                    assert commandText.contains("--ignore-weights YES")
                    assert !commandText.contains("--weights ")
                },
                {
                    def stableGrm = process.out.ldak_grm.collect { grmTuple ->
                        [
                            grmTuple[0],
                            path(grmTuple[1]).fileName.toString(),
                            path(grmTuple[2]).fileName.toString(),
                            path(grmTuple[3]).fileName.toString(),
                            path(grmTuple[4]).fileName.toString()
                        ]
                    }
                    assert snapshot(
                        stableGrm,
                        process.out.findAll { key, val -> key.startsWith("versions") }
                    ).match()
                }
            )
        }
    }

    test("homo_sapiens popgen - weighted kinship") {

        when {
            process {
                """
                input[0] = [
                    [ id: "plink_simulated_weighted" ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bed", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bim", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.fam", checkIfExists: true)
                ]
                input[1] = "-1"
                input[2] = CREATE_THIN_WEIGHTS.out.thin_weights
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.ldak_grm.size() == 1 },
                {
                    def grmBin = path(process.out.ldak_grm.get(0).get(1))
                    def commandText = grmBin.parent.resolve(".command.sh").text
                    assert commandText.contains("--power -1")
                    assert commandText.contains("--weights ")
                    assert !commandText.contains("--ignore-weights YES")
                }
            )
        }
    }

    test("homo_sapiens popgen - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id: "plink_simulated_stub" ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bed", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.bim", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/popgen/plink_simulated.fam", checkIfExists: true)
                ]
                input[1] = "-0.25"
                input[2] = [[:], []]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
