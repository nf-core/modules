nextflow_process {

    name "Test Process DASTOOL_SCAFFOLDS2BIN"
    script "../main.nf"
    process "DASTOOL_SCAFFOLDS2BIN"

    tag "modules"
    tag "modules_nfcore"
    tag "dastool"
    tag "dastool/scaffolds2bin"

    test("dastool fastatocontig2bin - bacteroides fragilis") {

        when {
            process {
                """
                input[0] = input[0] = Channel.of([
                    [ id:'test', single_end:false ],
                    file(params.modules_testdata_base_path + "genomics/prokaryotes/bacteroides_fragilis/genome/genome.fna.gz", checkIfExists: true)
                ])
                input[1] = 'fa'
                """
            }
        }

        then {
            assertAll(
                { assert process.failed },
            )
        }

    }
}
