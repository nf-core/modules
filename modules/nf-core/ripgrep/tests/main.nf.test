nextflow_process {

    name "Test Process RIPGREP"
    script "../main.nf"
    process "RIPGREP"

    tag "modules"
    tag "modules_nfcore"
    tag "ripgrep"

    test("generic - csv") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ], // meta map
                    file(params.modules_testdata_base_path + 'generic/csv/test.csv', checkIfExists: true),
                ]

                input[1] = 'Robert' // pattern
                input[2] = []
                input[3] = false // compress
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

    test("generic - csv - compress") {

            when {
                process {
                    """
                    input[0] = [
                        [ id:'test' ], // meta map
                        file(params.modules_testdata_base_path + 'generic/csv/test.csv', checkIfExists: true),
                    ]

                    input[1] = 'Robert' // pattern
                    input[2] = []
                    input[3] = true // compress
                    """
                }
            }

            then {
                assertAll(
                    { assert process.success },
                    { assert snapshot(process.out).match() }
                )
            }
    }

    test("generic - csv - pattern file") {

            setup {
                def pattern_file = new File("${launchDir}/pattern_file")
                pattern_file.text = "Robert"
            }

            when {
                process {
                    """
                    input[0] = [
                        [ id:'test' ], // meta map
                        file(params.modules_testdata_base_path + 'generic/csv/test.csv', checkIfExists: true),
                    ]

                    input[1] = []
                    input[2] = file("${launchDir}/pattern_file", checkIfExists: true)
                    input[3] = true // compress
                    """
                }
            }

            then {
                assertAll(
                    { assert process.success },
                    { assert snapshot(process.out).match() }
                )
            }
    }

    test("generic - csv - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ], // meta map
                    file(params.modules_testdata_base_path + 'generic/csv/test.csv', checkIfExists: true),
                ]

                input[1] = 'Robert' // pattern
                input[2] = []
                input[3] = false // compress
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

}
