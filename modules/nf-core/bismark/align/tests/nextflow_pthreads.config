process {
    // Force enough cpus that the intra-instance `-p` divisor emits `-p` (>= 2 threads
    // per strand instance): at 8 cpus, directional -> -p 4, non-directional -> -p 2,
    // combined (n=1) -> -p 8.
    withName: BISMARK_ALIGN {
        cpus     = 8
        ext.args = params.bismark_args
    }
    // Genome preparation takes ONLY the aligner-selection (and, for the combined test,
    // --combined_genome) flags — NOT --non_directional / --combined_index, which the
    // bismark_genome_preparation parser rejects. Kept as a separate param so alignment
    // flags never leak into the prep command.
    withName: BISMARK_GENOMEPREPARATION {
        ext.args = params.genomeprep_args
    }
}
