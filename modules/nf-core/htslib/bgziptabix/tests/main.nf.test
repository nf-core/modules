    test("illegal action") {

         when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/vcf/test.vcf', checkIfExists: true),
                ]
                input[1] = 'invalid_action' // action
                input[2] = true // make_index
                input[3] = 'vcf' // out_ext
                """
            }
        }

        then {
            assert process.failed
            assert process.errorReport.contains("Invalid action: invalid_action. Allowed actions are: compress, decompress")
        }

    }

