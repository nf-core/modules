nextflow_process {

    name "Test Process GCTA_FILTERGRMWITHKEEP"
    script "../main.nf"
    process "GCTA_FILTERGRMWITHKEEP"

    tag "modules"
    tag "modules_nfcore"
    tag "gcta"
    tag "gcta/filtergrmwithkeep"
    tag "tests/helpers/dense_grm"

    setup {
        run("GCTA_TEST_DENSE_GRM", alias: "GCTA_TEST_DENSE_GRM_CONTRACT") {
            script "../tests/helpers/dense_grm/main.nf"
            process {
                """
                input[0] = [
                    [ id:'contract_dense' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/popgen/plink_simulated.bed', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/popgen/plink_simulated.bim', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/popgen/plink_simulated.fam', checkIfExists: true)
                ]
                """
            }
        }

        run("GCTA_TEST_DENSE_GRM", alias: "GCTA_TEST_DENSE_GRM_STUB") {
            script "../tests/helpers/dense_grm/main.nf"
            process {
                """
                input[0] = [
                    [ id:'stub_dense' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/popgen/plink_simulated.bed', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/popgen/plink_simulated.bim', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/popgen/plink_simulated.fam', checkIfExists: true)
                ]
                """
            }
        }
    }

    test("homo_sapiens popgen - filter dense GRM with keep file") {
        config "./nextflow.config"

        when {
            process {
                """
                file('contract_keep.keep').text = "fid1 iid1\\n"

                input[0] = GCTA_TEST_DENSE_GRM_CONTRACT.out.dense_grm
                input[1] = Channel.value([
                    [ id:'contract_keep' ],
                    file('contract_keep.keep')
                ])
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.filtered_grm.size() == 1 },
                { assert process.out.filtered_grm.get(0).get(0).id == "contract_dense" },
                { assert snapshot(process.out.filtered_grm).match("filtered_grm") },
                { assert snapshot(process.out.findAll { key, val -> key.startsWith('versions') }).match("versions") }
            )
        }
    }

    test("homo_sapiens popgen - fail when meta id does not match dense GRM basename") {
        config "./nextflow.config"

        when {
            process {
                """
                file('contract_keep.keep').text = "fid1 iid1\\n"

                input[0] = GCTA_TEST_DENSE_GRM_CONTRACT.out.dense_grm.map { meta, grm_id, grm_bin, grm_n_bin ->
                    [[ id:'contract_dense_mismatch' ], grm_id, grm_bin, grm_n_bin]
                }
                input[1] = Channel.value([
                    [ id:'contract_keep' ],
                    file('contract_keep.keep')
                ])
                """
            }
        }

        then {
            assertAll(
                { assert !process.success },
                { assert process.exitStatus != 0 }
            )
        }
    }

    test("homo_sapiens popgen - filter dense GRM with keep file - stub") {
        options "-stub"
        config "./nextflow.config"

        when {
            process {
                """
                file('stub_keep.keep').text = "fid1 iid1\\n"

                input[0] = GCTA_TEST_DENSE_GRM_STUB.out.dense_grm
                input[1] = Channel.value([
                    [ id:'stub_keep' ],
                    file('stub_keep.keep')
                ])
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.filtered_grm.size() == 1 },
                { assert process.out.filtered_grm.get(0).get(0).id == "stub_dense" },
                { assert snapshot(process.out.filtered_grm).match("stub_filtered_grm") },
                { assert snapshot(process.out.findAll { key, val -> key.startsWith('versions') }).match("stub_versions") }
            )
        }
    }
}
