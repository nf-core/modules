// nf-core modules test pmlst
nextflow_process {

    name "Test Process PMLST"
    script "../main.nf"
    process "PMLST"

    tag "modules"
    tag "modules_nfcore"
    tag "modules_nfeit"
    tag "pmlst"

    test("sarscov2 - fasta - stub") {

        options "-stub"

        when {
            process {
                """
                def pmlst_db = file("pmlst_db")
                pmlst_db.mkdirs()

                input[0] = [
                    [ id:'test', single_end:false ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true)
                ]
                input[1] = pmlst_db
                input[2] = "incf"
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

}
