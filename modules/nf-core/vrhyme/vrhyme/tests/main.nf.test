
nextflow_process {

    name "Test Process VRHYME_VRHYME"
    script "../main.nf"
    process "VRHYME_VRHYME"

    tag "modules"
    tag "modules_nfcore"
    tag "modules_vrhyme"
    tag "vrhyme"
    tag "vrhyme/vrhyme"

    test("test-vrhyme-vrhyme") {

        when {
            process {
                """
                input[0] = [
				    [ id:'test', single_end:false ],
				    [
				        file(params.modules_testdata_base_path + 'genomics/prokaryotes/bacteroides_fragilis/illumina/fastq/test1_1.fastq.gz', checkIfExists: true),
				        file(params.modules_testdata_base_path + 'genomics/prokaryotes/bacteroides_fragilis/illumina/fastq/test1_2.fastq.gz', checkIfExists: true)
				    ]
				]
				input[1] = [
				    [ id:'test', single_end:false ],
				    file(params.modules_testdata_base_path + 'genomics/prokaryotes/bacteroides_fragilis/illumina/fasta/test1.contigs.fa.gz', checkIfExists: true)
				]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    sanitizeOutput(process.out, unstableKeys: ["bins", "summary"])
                    ).match()
                }
            )
        }
    }

    test("test-vrhyme-vrhyme-stub") {
        options '-stub'
        when {
            process {
                """
                input[0] = [
				    [ id:'test', single_end:false ],
				    [
				        file(params.modules_testdata_base_path + 'genomics/prokaryotes/bacteroides_fragilis/illumina/fastq/test1_1.fastq.gz', checkIfExists: true),
				        file(params.modules_testdata_base_path + 'genomics/prokaryotes/bacteroides_fragilis/illumina/fastq/test1_2.fastq.gz', checkIfExists: true)
				    ]
				]
				input[1] = [
				    [ id:'test', single_end:false ],
				    file(params.modules_testdata_base_path + 'genomics/prokaryotes/bacteroides_fragilis/illumina/fasta/test1.contigs.fa.gz', checkIfExists: true)
				]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }

}
