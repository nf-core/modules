nextflow_process {

    name "Test Process UPP_ALIGN"
    script "../main.nf"
    process "UPP_ALIGN"

    tag "modules"
    tag "modules_nfcore"
    tag "upp"
    tag "upp/align"
    tag "famsa/guidetree"

    test("fasta - align_sequence - uncompressed") {
        config "./nextflow.config"

        when {
            params {
                module_args = '-m amino'
            }

            process {
                """
                input[0] = [
                    [ id:'aln_uncompressed' ],
                    file("https://raw.githubusercontent.com/nf-core/test-datasets/multiplesequencealign/testdata/setoxin-ref.fa", checkIfExists: true)
                ]
                input[1] = [[:],[]]
                input[2] = [[:],[]]
                input[3] = false
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("fasta - align_sequence - compressed") {
        config "./nextflow.config"

        when {
            params {
                module_args = '-m amino'
            }

            process {
                """
                input[0] = [
                    [ id:'aln_compressed' ],
                    file("https://raw.githubusercontent.com/nf-core/test-datasets/multiplesequencealign/testdata/setoxin-ref.fa", checkIfExists: true)
                ]
                input[1] = [[:],[]]
                input[2] = [[:],[]]
                input[3] = true
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("fasta - with_tree - uncompressed") {
        config "./nextflow.config"

        setup {
            run("FAMSA_GUIDETREE") {
                script "../../../famsa/guidetree/main.nf"
                process {
                    """
                    input[0] = [
                        [ id:'famsa_tree' ],
                        file("https://raw.githubusercontent.com/nf-core/test-datasets/multiplesequencealign/testdata/setoxin-ref.fa", checkIfExists: true)
                    ]
                    """
                }
            }

            run("FAMSA_ALIGN") {
                script "../../../famsa/align/main.nf"
                process {
                    """
                    input[0] = [
                        [ id:'famsa_aln' ],
                        file("https://raw.githubusercontent.com/nf-core/test-datasets/multiplesequencealign/testdata/setoxin-ref.fa", checkIfExists: true)
                    ]
                    input[1] = FAMSA_GUIDETREE.out.tree.collect{ meta, tree -> tree }.map{ tree -> [[ id: 'famsa_tree'], tree ]}
                    input[2] = false
                    """
                }
            }
        }

        when {
            params {
                module_args = '-m amino'
            }

            process {
                """
                input[0] = [
                    [ id:'guided_uncompressed' ],
                    file("https://raw.githubusercontent.com/nf-core/test-datasets/multiplesequencealign/testdata/toxin-ref.fa", checkIfExists: true)
                ]
                input[1] = FAMSA_GUIDETREE.out.tree.collect{ meta, tree -> tree }.map{ tree -> [[ id: 'famsa_tree'], tree ]}
                input[2] = FAMSA_ALIGN.out.alignment.collect{ meta, alignment -> alignment }.map{ alignment -> [[ id: 'famsa_aln'], alignment ]}
                input[3] = false
                """
            }
        }

        then {
            // The alignment can change between runs depending on how random splits are made, so now
            // we just count the number of output lines.

            def result_file = file(process.out.alignment[0][1])
            assertAll(
                { assert process.success },
                { assert snapshot(
                    result_file.name,
                    result_file.readLines().size(),
                    process.out.findAll { key, val -> key.startsWith('versions') }
                ).match() }
            )
        }
    }

    test("stub") {
        config "./nextflow.config"

        options "-stub"
        when {
            params {
                module_args = '-m amino'
            }

            process {
                """
                input[0] = [
                    [ id:'stub' ],
                    file("https://raw.githubusercontent.com/nf-core/test-datasets/multiplesequencealign/testdata/setoxin-ref.fa", checkIfExists: true)
                ]
                input[1] = [[:],[]]
                input[2] = [[:],[]]
                input[3] = false
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
