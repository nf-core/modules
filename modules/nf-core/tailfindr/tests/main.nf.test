
nextflow_process {

    name "Test Process TAILFINDR"
    script "../main.nf"
    process "TAILFINDR"

    tag "modules"
    tag "modules_nfcore"
    tag "tailfindr"

    test("test-tailfindr") {

        when {
            process {
                """
                input[0] = [
				    [ id: 'test' ], // meta map
				    file('https://github.com/nf-core/test-datasets/raw/modules/data/delete_me/tailfindr/test.fast5', checkIfExists: true)
				]

                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    process.out.csv_gz[0][1] ==~ ".*.csv.gz" ? true : false,
                    process.out.versions_tailfindr,
                    process.out.versions_ont_fast5_api
                ).match() }
            )
        }
    }

    test("test-tailfindr-stub") {
        options "-stub"

        when {
            process {
                """
                input[0] = [
				    [ id: 'test' ], // meta map
				    file('https://github.com/nf-core/test-datasets/raw/modules/data/delete_me/tailfindr/test.fast5', checkIfExists: true)
				]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    process.out.csv_gz[0][1] ==~ ".*.csv.gz" ? true : false,
                    process.out.versions_tailfindr,
                    process.out.versions_ont_fast5_api
                ).match() }
            )
        }
    }

}
