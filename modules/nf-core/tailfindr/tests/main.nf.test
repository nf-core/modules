
nextflow_process {

    name "Test Process TAILFINDR"
    script "../main.nf"
    process "TAILFINDR"

    tag "modules"
    tag "modules_nfcore"
    tag "tailfindr"

    test("test-tailfindr") {

        when {
            process {
                """
                input[0] = [
				    [ id: 'test' ], // meta map
				    file('https://github.com/nf-core/test-datasets/raw/modules/data/delete_me/tailfindr/test.fast5', checkIfExists: true)
				]

                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
				    process.out.csv_gz,
				    process.out.versions_tailfindr
				    ).match() },
                { assert snapshot(process.out.versions_tailfindr).match("versions") }
            )
        }
    }

    test("test-tailfindr - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
				    [ id: 'test' ], // meta map
				    file('https://github.com/nf-core/test-datasets/raw/modules/data/delete_me/tailfindr/test.fast5', checkIfExists: true)
				]

                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }

}
