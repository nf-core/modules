nextflow_process {

    name "Test Process APBS"
    script "../main.nf"
    process "APBS"
    config "./nextflow.config"

    tag "modules"
    tag "modules_nfcore"
    tag "apbs"

    test("water - pqr_in - dx") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file("${projectDir}/modules/nf-core/apbs/tests/test.in", checkIfExists: true)
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(
                    process.out.dx,
                    path(process.out.log[0][1]).readLines().size(),
                    process.out.versions_apbs
                ).match() }
            )
        }

    }

    test("water - pqr_in - dx - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file("${projectDir}/modules/nf-core/apbs/tests/test.in", checkIfExists: true)
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }

    }

}
