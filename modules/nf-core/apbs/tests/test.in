read
    mol pqr test.pqr
end

elec name comp_solv
    mg-auto
    mol 1
    fgcent mol 1
    cgcent mol 1
    fglen 20.0 20.0 20.0
    cglen 40.0 40.0 40.0
    dime 33 33 33
    lpbe
