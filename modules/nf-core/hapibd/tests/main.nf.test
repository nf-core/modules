
nextflow_process {

    name "Test Process HAPIBD"
    script "../main.nf"
    process "HAPIBD"

    tag "modules"
    tag "modules_nfcore"
    tag "hapibd"

    test("test-hapibd") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'delete_me/hapibd/target.truth.vcf.gz', checkIfExists: true)
                ]
                input[1] = file(params.modules_testdata_base_path + 'delete_me/hapibd/target.map', checkIfExists: true)
                input[2] = []
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert file(process.out.log[0][1]).text.contains('End Time') },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["hbd", "ibd", "log"])).match()}
            )
        }
    }

    test("test-hapibd-excludesamples") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'delete_me/hapibd/target.truth.vcf.gz', checkIfExists: true)
                ]
                input[1] = file(params.modules_testdata_base_path + 'delete_me/hapibd/target.map', checkIfExists: true)
                input[2] = file(params.modules_testdata_base_path + 'delete_me/hapibd/excludeSamples.txt', checkIfExists: true)
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert file(process.out.log[0][1]).text.contains('End Time') },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["hbd", "ibd", "log"])).match()}
            )
        }
    }

    test("test-hapibd-excludesamples-stub") {
        options '-stub'

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'delete_me/hapibd/target.truth.vcf.gz', checkIfExists: true)
                ]
                input[1] = file(params.modules_testdata_base_path + 'delete_me/hapibd/target.map', checkIfExists: true)
                input[2] = file(params.modules_testdata_base_path + 'delete_me/hapibd/excludeSamples.txt', checkIfExists: true)
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }

}
