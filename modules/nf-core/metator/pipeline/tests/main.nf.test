// nf-core modules test metator/pipeline
nextflow_process {

    name "Test Process METATOR_PIPELINE"
    script "../main.nf"
    process "METATOR_PIPELINE"

    tag "modules"
    tag "modules_nfcore"
    tag "metator"
    tag "metator/pipeline"

    test("metator - fastq - nodepths") {

        when {

            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + "delete_me/metator/assembly.fa", checkIfExists: true),
                    [
                        file(params.modules_testdata_base_path + "delete_me/metator/for_paired.fq.gz", checkIfExists: true),
                        file(params.modules_testdata_base_path + "delete_me/metator/rev_paired.fq.gz", checkIfExists: true)
                    ],
                    []
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }

    }

    test("metator - fastq - depths") {

        when {

            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + "delete_me/metator/assembly.fa", checkIfExists: true),
                    [
                        file(params.modules_testdata_base_path + "delete_me/metator/for_paired.fq.gz", checkIfExists: true),
                        file(params.modules_testdata_base_path + "delete_me/metator/rev_paired.fq.gz", checkIfExists: true)
                    ],
                    file(params.modules_testdata_base_path + "delete_me/metator/depth.txt", checkIfExists: true)
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }

    }

    test("metator - bam - nodepths") {

        when {

            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + "delete_me/metator/assembly.fa", checkIfExists: true),
                    [
                        file(params.modules_testdata_base_path + "delete_me/metator/alignment_0_for.bam", checkIfExists: true),
                        file(params.modules_testdata_base_path + "delete_me/metator/alignment_0_rev.bam", checkIfExists: true)
                    ],
                    []
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("metator - pairs - nodepths") {

        when {

            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + "delete_me/metator/assembly.fa", checkIfExists: true),
                    file(params.modules_testdata_base_path + "delete_me/metator/alignment.pairs.gz", checkIfExists: true),
                    []
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("metator - fastq - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + "delete_me/metator/assembly.fa", checkIfExists: true),
                    [
                        file(params.modules_testdata_base_path + "delete_me/metator/for_paired.fq.gz", checkIfExists: true),
                        file(params.modules_testdata_base_path + "delete_me/metator/rev_paired.fq.gz", checkIfExists: true)
                    ],
                    []
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }

    }

}
