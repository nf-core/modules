    test("metator - fastq - stub") {

        options "-stub"

        when {

            params {
                metator_args = "-s 30000 -e HindIII,DpnII"
            }

            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + "delete_me/metator/assembly.fa.gz", checkIfExists: true),
                    [
                        file(params.modules_testdata_base_path + "delete_me/metator/for_paired.fq.gz", checkIfExists: true),
                        file(params.modules_testdata_base_path + "delete_me/metator/rev_paired.fq.gz", checkIfExists: true)
                    ],
                    []
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }

    }

}
