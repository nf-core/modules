nextflow_process {

    name "Test Process OPENMS_PSMFEATUREEXTRACTOR"
    script "../main.nf"
    process "OPENMS_PSMFEATUREEXTRACTOR"
    config "./nextflow.config"

    tag "modules"
    tag "modules_nfcore"
    tag "openms"
    tag "openms/psmfeatureextractor"
    tag "openmsthirdparty/cometadapter"
    tag "openms/decoydatabase"
    tag "thermorawfileparser"

    setup {
        run("THERMORAWFILEPARSER") {
            script "../../../thermorawfileparser/main.nf"
            process {
                """
                input[0] = channel.of([
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'proteomics/msspectra/PXD012083_e005640_II.raw', checkIfExists: true)
                ])
                """
            }
        }

        run("OPENMS_DECOYDATABASE") {
            script "../../../openms/decoydatabase/main.nf"
            process {
                """
                input[0] = channel.of([
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'proteomics/database/UP000005640_9606.fasta', checkIfExists: true)
                ])
                """
            }
        }

        run("OPENMSTHIRDPARTY_COMETADAPTER") {
            script "../../../openmsthirdparty/cometadapter/main.nf"
            process {
                """
                input[0] =
                    THERMORAWFILEPARSER.out.spectra.join(
                    OPENMS_DECOYDATABASE.out.decoy_fasta
                    )
                """
            }
        }
    }

    test("proteomics - psmfeatureextractor - idxml") {

        when {
            process {
                """
                input[0] = OPENMSTHIRDPARTY_COMETADAPTER.out.idxml
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert file(process.out.idxml[0][1]).readLines().any { it.contains('PeptideHit') } },
                // Snapshot stable XML header + SearchParameters (lines 1-92), skipping timestamp on line 93
                { assert snapshot(
                    file(process.out.idxml[0][1]).readLines()[0..91].join('\n').md5(),
                    process.out.findAll { key, val -> key.startsWith('versions') }
                ).match() }
            )
        }
    }

    test("proteomics - psmfeatureextractor - idxml - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = OPENMSTHIRDPARTY_COMETADAPTER.out.idxml
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
