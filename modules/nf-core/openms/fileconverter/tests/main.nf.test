nextflow_process {

    name "Test Process OPENMS_FILECONVERTER"
    script "../main.nf"
    process "OPENMS_FILECONVERTER"

    tag "modules"
    tag "modules_nfcore"
    tag "openms"
    tag "openms/fileconverter"

    test("proteomics - mzML - to mgf") {

        config "./nextflow.config"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'proteomics/msspectra/peakpicker_tutorial_1.mzML', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("proteomics - mzML - to mgf - stub") {

        options "-stub"
        config "./nextflow.config"

        when {
            process {
                """
                input[0] = [
                    [ id:'test_stub' ],
                    file(params.modules_testdata_base_path + 'proteomics/msspectra/peakpicker_tutorial_1.mzML', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
