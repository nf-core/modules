nextflow_process {

    name "Test Process STARDIST on GPU"
    script "../main.nf"
    process "STARDIST"

    tag "modules"
    tag "modules_nfcore"
    tag "stardist"
    tag "gpu"

    test("stardist2d - gpu - tif") {

        when {
            config "./nextflow.config"
            process {
                """
                input[0] = [
                    [ id:'test' ], // meta map
                    file(params.modules_testdata_base_path + 'imaging/segmentation/nuclear_image.tif', checkIfExists: true)
                ]
                input[1] = [ '2D_versatile_fluo', [] ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

    test("stardist2d - gpu - tif - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ], // meta map
                    file(params.modules_testdata_base_path + 'imaging/segmentation/nuclear_image.tif', checkIfExists: true)
                ]
                input[1] = [ '2D_versatile_fluo', [] ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

}
