nextflow_process {

    name "Test Process GEMMI_CIF2MTZ"
    script "../main.nf"
    process "GEMMI_CIF2MTZ"

    tag "modules"
    tag "modules_nfcore"
    tag "gemmi"
    tag "gemmi/cif2mtz"

    test("cif - mtz") {

        when {
            process {
                """    
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'proteomics/cif/1AB0-sf.cif', checkIfExists: true),
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }

    }

    test("cif - mtz - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'proteomics/cif/1AB0-sf.cif', checkIfExists: true),
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }

    }
}
