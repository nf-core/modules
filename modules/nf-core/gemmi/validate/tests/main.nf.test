nextflow_process {

    name "Test Process GEMMI_VALIDATE"
    script "../main.nf"
    process "GEMMI_VALIDATE"

    tag "modules"
    tag "modules_nfcore"
    tag "gemmi"
    tag "gemmi/validate"

    test("cif - cif") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'proteomics/cif/1AB0-sf.cif', checkIfExists: true),
                ]
                """
            }
        }

        then {
            assert process.success
        }

    }

    test("cif - cif - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'proteomics/cif/1AB0-sf.cif', checkIfExists: true),
                ]
                """
            }
        }

        then {
            assert process.success
        }

    }

}
