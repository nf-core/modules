// nf-core modules test anarcii
nextflow_process {

    name "Test Process ANARCII"
    script "../main.nf"
    process "ANARCII"

    tag "modules"
    tag "modules_nfcore"
    tag "anarcii"

    test("human - fasta") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/fasta/alz.ccs.fasta', checkIfExists: true),
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(
                    process.out,
                ).match() }
            )
        }

    }

    test("human - fasta - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/fasta/alz.ccs.fasta', checkIfExists: true),
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(
                    process.out,
                ).match() }
            )
        }

    }

}
