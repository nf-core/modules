nextflow_process {

    name "Test Process CHELAE_TRIM"
    script "../main.nf"
    process "CHELAE_TRIM"
    config "./nextflow.config"

    tag "modules"
    tag "modules_nfcore"
    tag "chelae"
    tag "chelae/trim"
    tag "htslib/bgziptabix"

    test("sarscov2 - single_end - fastq") {

        when {
            params {
                module_args = ''
            }
            process {
                """
                input[0] = [
                    [ id:'test', single_end:true ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true)
                ]
                input[1] = []
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys: ["json"])).match() }
            )
        }
    }

    test("sarscov2 - paired_end - fastq") {

        when {
            params {
                module_args = ''
            }
            process {
                """
                input[0] = [
                    [ id:'test', single_end:false ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ]
                input[1] = []
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys: ["json"])).match() }
            )
        }
    }

    test("sarscov2 - paired_end - fastq - adapter_fasta") {

        when {
            params {
                module_args = ''
            }
            process {
                """
                input[0] = [
                    [ id:'test', single_end:false ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ]
                input[1] = file(params.modules_testdata_base_path + 'delete_me/fastp/adapters.fasta', checkIfExists: true)
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys: ["json"])).match() }
            )
        }
    }

    test("sarscov2 - single_end - plain fastq") {

        setup {
            run("HTSLIB_BGZIPTABIX", alias: "HTSLIB_BGZIPTABIX_DECOMPRESS") {
                script "../../../htslib/bgziptabix/main.nf"
                process {
                    """
                    input[0] = [
                        [ id:'test', single_end:true ],
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        [],
                        []
                    ]
                    input[1] = 'decompress'
                    input[2] = false
                    input[3] = 'fastq'
                    """
                }
            }
        }

        when {
            params {
                module_args = ''
            }
            process {
                """
                input[0] = HTSLIB_BGZIPTABIX_DECOMPRESS.out.output
                input[1] = []
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    sanitizeOutput(process.out, unstableKeys: ["reads", "json"]),
                    path(process.out.reads[0][1]).fastq.numberOfRecords
                ).match() }
            )
        }
    }

    test("sarscov2 - single_end - bgzf fastq") {

        setup {
            run("HTSLIB_BGZIPTABIX") {
                script "../../../htslib/bgziptabix/main.nf"
                process {
                    """
                    input[0] = [
                        [ id:'test', single_end:true ],
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        [],
                        []
                    ]
                    input[1] = 'compress'
                    input[2] = false
                    input[3] = 'fastq'
                    """
                }
            }
        }

        when {
            params {
                module_args = ''
            }
            process {
                """
                input[0] = HTSLIB_BGZIPTABIX.out.output
                input[1] = []
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    sanitizeOutput(process.out, unstableKeys: ["reads", "json"]),
                    path(process.out.reads[0][1]).fastq.numberOfRecords
                ).match() }
            )
        }
    }

    test("sarscov2 - mismatched inputs and outputs - fails") {

        when {
            params {
                module_args = ''
            }
            process {
                """
                input[0] = [
                    [ id:'test', single_end:true ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ]
                input[1] = []
                """
            }
        }

        then {
            assert process.failed
        }
    }

    test("sarscov2 - single_end - fastq - stub") {

        options "-stub"

        when {
            params {
                module_args = ''
            }
            process {
                """
                input[0] = [
                    [ id:'test', single_end:true ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true)
                ]
                input[1] = []
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("sarscov2 - paired_end - fastq - stub") {

        options "-stub"

        when {
            params {
                module_args = ''
            }
            process {
                """
                input[0] = [
                    [ id:'test', single_end:false ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ]
                input[1] = []
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
