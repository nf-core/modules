nextflow_process {

    name "Test Process SUSHIE"
    script "../main.nf"
    process "SUSHIE"

    tag "modules"
    tag "modules_nfcore"
    tag "sushie"

    test("sushie - gwas") {

        when {
            process {
                """
                input[0] = [
                    [ id: 'test' ],
                    [ file('https://github.com/mancusolab/sushie/raw/main/data/AFR.gwas', checkIfExists: true) ]
                ]
                input[1] = [
                    file('https://github.com/mancusolab/sushie/raw/main/data/AFR.ld', checkIfExists: true)
                ]
                input[2] = "408112"
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("sushie - gwas - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id: 'test' ],
                    [ file('https://github.com/mancusolab/sushie/raw/main/data/AFR.gwas', checkIfExists: true) ]
                ]
                input[1] = [
                    file('https://github.com/mancusolab/sushie/raw/main/data/AFR.ld', checkIfExists: true)
                ]
                input[2] = "408112"
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
