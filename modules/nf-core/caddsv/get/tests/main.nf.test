nextflow_process {

    name "Test Process CADDSV_GET"
    script "../main.nf"
    process "CADDSV_GET"

    tag "modules"
    tag "modules_nfcore"
    tag "caddsv"
    tag "caddsv/get"

    test("caddsv-get - stub") {

        options "-stub"

        then {
            assert process.success
            assertAll(
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }

    }

}
