nextflow_process {

    name "Test Process FUNGTION_DOWNLOADMODELS"
    script "../main.nf"
    process "FUNGTION_DOWNLOADMODELS"

    tag "modules"
    tag "modules_nfcore"
    tag "fungtion"
    tag "fungtion/downloadmodels"

    test("stub") {

        options "-stub"

        when {
            process {
                """
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }

    }

}
