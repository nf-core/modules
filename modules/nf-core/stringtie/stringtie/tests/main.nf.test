nextflow_process {

    name "Test Process STRINGTIE_STRINGTIE"
    script "../main.nf"
    process "STRINGTIE_STRINGTIE"
    tag "modules"
    tag "modules_nfcore"
    tag "stringtie"
    tag "stringtie/stringtie"

    test("sarscov2 [bam] - forward strandedness - short read assembly") {

        when {
            process {
                """
                input[0] = [
                            [ id:'test', strandedness:'forward' ], // meta map
                            [ file(params.modules_testdata_base_path + "genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam", checkIfExists: true) ],
                            []
                        ]
                input[1] = []
                input[2] = []
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys: ["coverage_gtf", "abundance"])).match() }
            )
        }
    }

    test("sarscov2 [bam] - forward strandedness + reference annotation - short read assembly") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test', strandedness:'forward' ], // meta map
                    [ file(params.modules_testdata_base_path + "genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam", checkIfExists: true) ],
                    []
                ]
                input[1] = []
                input[2] = file(params.modules_testdata_base_path + "genomics/sarscov2/genome/genome.gtf", checkIfExists: true)
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys: ["coverage_gtf", "abundance"])).match() }
            )
        }
    }

