nextflow_process {

    name "Test Process CARVEME_CARVE"
    script "../main.nf"
    process "CARVEME_CARVE"
    config "./nextflow.config"

    tag "modules"
    tag "modules_nfcore"
    tag "carveme"
    tag "carveme/carve"

    test("candidatus_portiera_aleyrodidarum - proteome fasta - xml") {

        when {
            params {
                module_args = ""
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/prokaryotes/candidatus_portiera_aleyrodidarum/genome/proteome.fasta', checkIfExists: true),
                    [], [], [], [], []
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    path(process.out.model[0][1]).exists(),
                    process.out.findAll { key, val -> key.startsWith("versions") }
                ).match() }
            )
        }
    }

    test("cazymes - faa - mediadb - debug - xml") {

        when {
            params {
                module_args = "--debug --gapfill LB,M9"
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'proteomics/database/protein_mini_with_cazymes.faa', checkIfExists: true),
                    [],
                    file(params.modules_testdata_base_path + 'generic/tsv/media_db.tsv', checkIfExists: true),
                    [], [], []
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    path(process.out.model[0][1]).exists(),
                    process.out.gene_scores,
                    process.out.milp_problem,
                    process.out.milp_solution,
                    process.out.protein_scores,
                    process.out.reaction_scores,
                    process.out.findAll { key, val -> key.startsWith("versions") }
                ).match() }
            )
        }
    }

    test("candidatus_portiera_aleyrodidarum - proteome fasta - xml - stub") {

        options "-stub"

        when {
            params {
                module_args = ""
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/prokaryotes/candidatus_portiera_aleyrodidarum/genome/proteome.fasta', checkIfExists: true),
                    [], [], [], [], []
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }
}
