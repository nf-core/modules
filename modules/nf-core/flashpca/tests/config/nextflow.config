// tests/config/nextflow.config

profiles {
    test {
        params {
            input = "${projectDir}/tests/test_data/HM3_thinned_autosomal_overlap.{bed,bim,fam}"
        }
    }
}

// Use Docker for tests (most reliable on GitHub Actions)
docker {
    enabled = true
    runOptions = '--platform linux/amd64'
}

// Fallback: Apptainer with disabled auto-mounts (if you want to test it)
apptainer {
    enabled = false
    // Uncomment the block below only if you need to test Apptainer locally
    // enabled = true
    // autoMounts = false
    // runOptions = '--no-mount tmp,dev,proc,sys'
}
