nextflow_process {

    name "Test Process CNVKIT_COVERAGE"
    script "../main.nf"
    process "CNVKIT_COVERAGE"



    tag "modules"
    tag "modules_nfcore"
    tag "cnvkit"
    tag "cnvkit/coverage"

    test("test-cnvkit-coverage - cnn") {

        when {

            process {
                """
                               
                input[0] = [
                    [ id: 'test' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true ),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.bins_10kb_annotated.bed', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(
                    process.out
                ).match() }
            )
        }

    }

    test("test-cnvkit-coverage - cnn - stub") {

        options "-stub"

        when {
            process {
                """
                
                input[0] = [
                    [ id:'test'],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.bins_10kb_annotated.bed', checkIfExists: true)]
                
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(
                    process.out
                ).match() }
            )
        }

    }

}
