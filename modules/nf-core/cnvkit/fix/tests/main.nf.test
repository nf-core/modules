nextflow_process {

    name "Test Process CNVKIT_FIX"
    script "../main.nf"
    process "CNVKIT_FIX"

    tag "modules"
    tag "modules_nfcore"
    tag "cnvkit"
    tag "cnvkit/fix"

    test("test-cnvkit-fix - cnr") {

        when {
            process {
                """

                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/cnvkit/test.targetcoverage.cnn',checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/cnvkit/test.antitargetcoverage.cnn',checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/cnvkit/test_reference.cnn',checkIfExists: true)
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                {   assert snapshot(sanitizeOutput(process.out)).match()}
            )
        }

    }

    test("test-cnvkit-fix - cnn - stub") {

        options "-stub"

        when {
            process {
                """

                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/cnvkit/test.targetcoverage.cnn',checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/cnvkit/test.antitargetcoverage.cnn',checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/cnvkit/test_reference.cnn',checkIfExists: true)
                ]
                """
            }
        }

        then {
            assert process.success
             assertAll(
                { assert snapshot(
                    process.out
                ).match() }
            )
        }

    }

}
