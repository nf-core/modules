nextflow_process {
    name "Test Process DOTMATCH_DEMUX"
    script "../main.nf"
    process "DOTMATCH_DEMUX"

    test("runs tiny barcode demux fixture") {
        when {
            process {
                """
                input[0] = Channel.of([
                    [id: 'barcode_demux'],
                    file('data/barcode_reads.fastq'),
                    file('data/barcodes.tsv')
                ])
                input[1] = 0
                input[2] = 4
                input[3] = 0
                input[4] = 'hamming'
                """
            }
        }

        then {
            assert process.success
            assert path(process.out.demuxed[0][1]).toFile().isDirectory()
            assert path(process.out.summary[0][1]).text.contains("assigned_unique")
            assert path(process.out.assignments[0][1]).text.contains("bc_a_exact")
            assert path(process.out.versions[0]).text.contains("dotmatch")
        }
    }
}
