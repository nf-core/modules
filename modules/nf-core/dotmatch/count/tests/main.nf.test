nextflow_process {
    name "Test Process DOTMATCH_COUNT"
    script "../main.nf"
    process "DOTMATCH_COUNT"

    test("runs tiny fixed-window count fixture") {
        when {
            process {
                """
                input[0] = Channel.of([
                    [id: 'barcode_count'],
                    file('data/barcode_reads.fastq'),
                    file('data/barcodes.tsv')
                ])
                input[1] = 0
                input[2] = 4
                input[3] = 0
                input[4] = 'hamming'
                """
            }
        }

        then {
            assert process.success
            assert path(process.out.counts[0][1]).text.contains("bc_a")
            assert path(process.out.sample_qc[0][1]).text.contains("assignment_rate")
            assert path(process.out.assignments[0][1]).text.contains("bc_a_exact")
            assert path(process.out.versions[0]).text.contains("dotmatch")
        }
    }
}
