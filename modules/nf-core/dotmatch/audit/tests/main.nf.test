nextflow_process {
    name "Test Process DOTMATCH_AUDIT"
    script "../main.nf"
    process "DOTMATCH_AUDIT"

    test("runs tiny target audit fixture") {
        when {
            process {
                """
                input[0] = Channel.of([
                    [id: 'barcode_audit'],
                    file('data/barcodes.tsv')
                ])
                input[1] = 1
                input[2] = 'exact'
                """
            }
        }

        then {
            assert process.success
            assert path(process.out.summary_json[0][1]).text.contains("min_hamming_distance")
            assert path(process.out.summary_tsv[0][1]).text.contains("safe_at_hamming")
            assert path(process.out.target_safety[0][1]).text.contains("target_id")
            assert path(process.out.versions[0]).text.contains("dotmatch")
        }
    }
}
