// nf-core modules test macse/refinealignment
nextflow_process {

    name "Test Process MACSE_REFINEALIGNMENT"
    script "../main.nf"
    process "MACSE_REFINEALIGNMENT"

    tag "modules"
    tag "modules_nfcore"
    tag "macse"
    tag "macse/refinealignment"

    test("Raphidioptera - fasta") {
        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file('https://github.com/nf-core/test-datasets/blob/5636177eb32fef2c40032826233be58e52ba3bef/data/genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true),
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot (
                    process.out.aa,
                    process.out.nt,
                    process.out.findAll { key, val -> key.startsWith("versions")}
                ).match()}
            )
        }

    }

    test("Raphidioptera - fasta - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file('https://github.com/nf-core/test-datasets/blob/5636177eb32fef2c40032826233be58e52ba3bef/data/genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true),
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot (
                    process.out.aa,
                    process.out.nt,
                    process.out.findAll { key, val -> key.startsWith("versions")}
                ).match()}
            )
        }

    }

}
