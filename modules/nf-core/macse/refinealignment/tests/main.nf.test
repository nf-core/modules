// nf-core modules test macse/refinealignment
nextflow_process {

    name "Test Process MACSE_REFINEALIGNMENT"
    script "../main.nf"
    process "MACSE_REFINEALIGNMENT"

    tag "modules"
    tag "modules_nfcore"
    tag "macse"
    tag "macse/refinealignment"

    test("Raphidioptera - fasta") {
        when {
            process {
                """               
                input[0] = [
                    [ id:'test' ],
                    file('https://www.agap-ge2pop.org/wp-content/uploads/macse/data/Ref_ali_files/Raphidioptera_BOLD_COI_final_align_NT.aln', checkIfExists: true),
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }

    }

    test("Raphidioptera - fasta - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file('https://www.agap-ge2pop.org/wp-content/uploads/macse/data/Ref_ali_files/Raphidioptera_BOLD_COI_final_align_NT.aln', checkIfExists: true),
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
             )
        }

    }

}