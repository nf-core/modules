nextflow_process {

    name "Test Process GAPSEQ_DOALL"
    script "../main.nf"
    process "GAPSEQ_DOALL"

    tag "modules"
    tag "modules_nfcore"
    tag "gapseq"
    tag "gapseq/doall"
    tag "pigz"
    tag "pigz/compress"

    test("gapseq toy myb71 proteome [faa.gz] + MM_glu medium") {

        config "./nextflow.config"

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test' ],
                    file('https://raw.githubusercontent.com/jotech/gapseq/master/toy/myb71.faa.gz', checkIfExists: true),
                    file('https://raw.githubusercontent.com/jotech/gapseq/master/dat/media/MM_glu.csv', checkIfExists: true)
                ])
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                {
                    assert snapshot(
                        process.out.log.collect { meta, files -> [meta, files.collect { file(it).getName() }.sort()] },
                        process.out.model.collect { meta, model -> [meta, (model instanceof List ? model : [model]).collect { file(it).getName() }.sort()] },
                        process.out.tbl.collect { meta, files -> [meta, files.collect { file(it).getName() }.sort()] },
                        process.out.findAll { key, val -> key.startsWith('versions') }
                    ).match()
                }
            )
        }
    }

    test("candidatus_portiera_aleyrodidarum proteome [fasta] - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test' ],
                    file(params.modules_testdata_base_path + 'genomics/prokaryotes/candidatus_portiera_aleyrodidarum/genome/proteome.fasta', checkIfExists: true),
                    []
                ])
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                {
                    assert snapshot(
                        process.out.log.collect { meta, files -> [meta, files.collect { file(it).getName() }.sort()] },
                        process.out.model.collect { meta, model -> [meta, (model instanceof List ? model : [model]).collect { file(it).getName() }.sort()] },
                        process.out.tbl.collect { meta, files -> [meta, files.collect { file(it).getName() }.sort()] },
                        process.out.findAll { key, val -> key.startsWith('versions') }
                    ).match()
                }
            )
        }
    }

    test("candidatus_portiera_aleyrodidarum proteome [fasta] + MM_glu medium - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test' ],
                    file(params.modules_testdata_base_path + 'genomics/prokaryotes/candidatus_portiera_aleyrodidarum/genome/proteome.fasta', checkIfExists: true),
                    file('https://raw.githubusercontent.com/jotech/gapseq/master/dat/media/MM_glu.csv', checkIfExists: true)
                ])
                """
            }
        }

        then {
            assertAll (
                { assert process.success },
                {
                    assert snapshot(
                        process.out.log.collect { meta, files -> [meta, files.collect { file(it).getName() }.sort()] },
                        process.out.model.collect { meta, model -> [meta, (model instanceof List ? model : [model]).collect { file(it).getName() }.sort()] },
                        process.out.tbl.collect { meta, files -> [meta, files.collect { file(it).getName() }.sort()] },
                        process.out.findAll { key, val -> key.startsWith('versions') }
                    ).match()
                }
            )
        }
    }

}
