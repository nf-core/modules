nextflow_process {

    name "Test Process KMCP_INDEX"
    script "../main.nf"
    process "KMCP_INDEX"
    config "./nextflow.config"

    tag "modules"
    tag "modules_nfcore"
    tag "kmcp"
    tag "kmcp/index"
    tag "kmcp/compute"

    setup {
        run("KMCP_COMPUTE") {
            script "../../../kmcp/compute/main.nf"
            process {
                """
                input[0] = [[id: 'test'],file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true)]
                """
            }
        }
    }

    test("sarscov2 - fasta") {
        when {
            process {
                """
                input[0] = KMCP_COMPUTE.out.outdir
                input[1] = [[],[]]
                input[2] = [[],[]]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                        process.out.kmcp,
                        process.out.findAll { key, val -> key.startsWith('versions') },
                        file(process.out.log[0][1]).any { it.contains('time elapsed') }
                    ).match()
                }
            )
        }

    }

    test("sarscov2 - fasta - with taxonomy") {
        when {
            process {
                """
                input[0] = KMCP_COMPUTE.out.outdir
                input[1] = [
                    [id: 'taxdmp'], 
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/metagenome/nodes.dmp', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/metagenome/names.dmp', checkIfExists: true)
                    ]
                ]
                input[2] = channel.of("genome\t2697049").collectFile(name:"genome2taxid.map", newLine:true).map{ mapfile -> [[id: 'genome2taxid'], mapfile]}
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                        process.out.kmcp,
                        process.out.findAll { key, val -> key.startsWith('versions') },
                        file(process.out.log[0][1]).any { it.contains('time elapsed') }
                    ).match()
                }
            )
        }

    }

    test("sarscov2 - fasta - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = KMCP_COMPUTE.out.outdir
                input[1] = [[],[]]
                input[2] = [[],[]]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

    test("sarscov2 - fasta - with-taxonomy stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = KMCP_COMPUTE.out.outdir
                input[1] = [
                    [id: 'taxdmp'], 
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/metagenome/nodes.dmp', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/metagenome/names.dmp', checkIfExists: true)
                    ]
                ]
                input[2] = [
                    [id: 'seqid2map'],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/metagenome/seqid2taxid.map', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

}
