nextflow_process {

    name "Test Process BUSCO_PLOT"
    script "../main.nf"
    process "BUSCO_PLOT"

    tag "modules"
    tag "modules_nfcore"
    tag "busco"
    tag "busco/busco"
    tag "busco/plot"

    test("bacteroides_fragilis-genome_fna_gz") {

        setup {
            run("BUSCO_BUSCO") {
                script "../../busco"
                process {
                    """
                    input[0] = [
                        [ id:'test' ], // meta map
                        file(params.modules_testdata_base_path + 'genomics/prokaryotes/bacteroides_fragilis/genome/genome.fna.gz', checkIfExists: true)
                    ]
                    input[1] = 'genome'
                    input[2] = 'bacteria_odb10'
                    input[3] = []
                    input[4] = []
                    input[5] = false
                    """
                }
            }
        }

        when {
            process {
                """
                input[0] = BUSCO_BUSCO.out.short_summaries_json.map { meta, summary -> summary }
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out.findAll { key, val -> key.startsWith("versions")}).match("versions") },
                // PNGs have same data but different meta-data, so md5 is unstable, check the filename instead
                { assert file(process.out.png[0]).name == "busco_figure.png" }
            )
        }

    }

    test("stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = file(params.modules_testdata_base_path + 'genomics/prokaryotes/bacteroides_fragilis/genome/genome.fna.gz', checkIfExists: true)
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

}
