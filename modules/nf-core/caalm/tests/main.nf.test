nextflow_process {

    name "Test Process CAALM"
    script "../main.nf"
    process "CAALM"
    config "./nextflow.config"

    tag "modules"
    tag "modules_nfcore"
    tag "caalm"

    test("cazyme - faa") {

        when {
            params {
                module_args = ""
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file("${projectDir}/modules/nf-core/caalm/tests/fixtures/protein_mini_with_cazymes.faa", checkIfExists: true)
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }

    }

    test("cazyme - faa - embeddings") {

        when {
            params {
                module_args = "--save-level0-embeddings --save-level1-embeddings --save-level2-embeddings"
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file("${projectDir}/modules/nf-core/caalm/tests/fixtures/protein_mini_with_cazymes.faa", checkIfExists: true)
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }

    }

    test("cazyme - faa - stub") {

        options "-stub"

        when {
            params {
                module_args = ""
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file("${projectDir}/modules/nf-core/caalm/tests/fixtures/protein_mini_with_cazymes.faa", checkIfExists: true)
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }

    }

    test("cazyme - faa - stub - embeddings") {

        options "-stub"

        when {
            params {
                module_args = "--save-level0-embeddings --save-level1-embeddings --save-level2-embeddings"
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file("${projectDir}/modules/nf-core/caalm/tests/fixtures/protein_mini_with_cazymes.faa", checkIfExists: true)
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }

    }

}
