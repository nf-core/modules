nextflow_process {

    name "Test Process BARRNAP"
    script "../main.nf"
    process "BARRNAP"
    tag "modules"
    tag "modules_nfcore"
    tag "barrnap"

    test("barrnap") {

        when {
            process {
                """
                input[0] = [
                                [ id:'test', single_end:false ], // meta map
                                file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fasta/contigs.fasta', checkIfExists: true),
                                "bac"
                            ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out.gff).match("gff") },
                { assert snapshot(process.out.versions_barrnap).match("versions") }
            )
        }
    }

    test("barrnap - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                                [ id:'test', single_end:false ], // meta map
                                file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fasta/contigs.fasta', checkIfExists: true),
                                "bac"
                            ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out.gff).match("gff_stub") },
                { assert snapshot(process.out.versions_barrnap).match("versions_stub") }
            )
        }
    }
}
