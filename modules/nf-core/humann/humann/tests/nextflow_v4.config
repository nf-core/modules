params {
    pipelines_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/funcprofiler/'
}

process {
    withName: 'HUMANN4_HUMANN' {
        container = 'ghcr.io/vdblab/biobakery-profiler:4.0.6--4.0.0.alpha.1-final_smaller-pt2'
    }
    withName: 'MPAHUMANN4' {
        ext.args = '-t rel_ab_w_read_stats'
    }
}
