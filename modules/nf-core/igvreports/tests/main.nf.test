nextflow_process {

    name "Test Process IGVREPORTS"
    script "../main.nf"
    config "./nextflow.config"
    process "IGVREPORTS"

    tag "modules"
    tag "modules_nfcore"
    tag "igvreports"

    test("variants with fasta - vcf") {

        when {
            params {
                module_args = ''
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/vcf/test.vcf', checkIfExists: true),
                    [], []
                ]
                input[1] = [
                    [ id: 'test_genome' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta.fai', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["report"])).match() }
            )
        }

    }


    test("variants with fasta and tracks - vcf") {

        when {
            params {
                module_args = ''
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/vcf/test.vcf', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam.bai', checkIfExists: true)
                ]
                input[1] = [
                    [ id: 'test_genome' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta.fai', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["report"])).match() }
            )
        }

    }


    test("variants with genome - vcf") {
        when {
            params {
                module_args = '--genome hg38'
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file("https://raw.githubusercontent.com/igvteam/igv-reports/master/test/data/variants/variants.vcf"),
                    [], []
                ]
                // Need to specify the empty optional fasta input
                input[1] = [ [:], [], [] ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["report"])).match() }
            )
        }

    }

    test("variant with genome - vcf - stub") {
        options "-stub"

        when {
            params {
                module_args = '--genome hg38'
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file("https://raw.githubusercontent.com/igvteam/igv-reports/master/test/data/variants/variants.vcf"),
                    [], []
                ]
                input[1] = [ [:], [], [] ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }

    }

}
