
nextflow_process {

    name "Test Process GAPPA_EXAMINEGRAFT"
    script "../main.nf"
    process "GAPPA_EXAMINEGRAFT"

    tag "modules"
    tag "modules_nfcore"
    tag "gappa"
    tag "gappa/examinegraft"

    test("test-gappa-examinegraft") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'delete_me/gappa/epa_result.jplace.gz', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }

    test("test-gappa-examinegraft-stub") {
        options '-stub'

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'delete_me/gappa/epa_result.jplace.gz', checkIfExists: true)
                ]

                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }

}
