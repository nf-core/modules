nextflow_process {

    name "Test Process OCTOPUSV_CORRECT"
    script "../main.nf"
    process "OCTOPUSV_CORRECT"

    tag "modules"
    tag "modules_nfcore"
    tag "octopusv"
    tag "octopusv/correct"

    test("homo_sapiens - vcf - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/vcf/gridss.somatic.vcf', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }

    }

}
