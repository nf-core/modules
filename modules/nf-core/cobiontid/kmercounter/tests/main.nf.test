nextflow_process {
    name "Test Process COBIONTID_KMERCOUNTER"
    script "../main.nf"
    process "COBIONTID_KMERCOUNTER"

    tag "modules"
    tag "modules_nfcore"
    tag "gunzip"
    tag "cobiontid"
    tag "cobiontid/kmercounter"

    setup {
        nfcoreInitialise("${launchDir}/library/")
        nfcoreInstall(
            "${launchDir}/library/",
            [ "gunzip" ]
        )
        nfcoreLink("${launchDir}/library/", "${baseDir}/modules/")

        run("GUNZIP"){
            script "modules/nf-core/gunzip/main.nf"
            process {
                """
                input[0] = [
                    [ id: "Homo_sapiens" ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/chr1/genome.fasta.gz', checkIfExists: true),
                ]
                """
            }
        }
    }

    test("kmercount - fasta") {
        when {
            process {
                """
                input[0] = GUNZIP.out.gunzip
                input[1] = 11
                """
            }
        }

        then {
            assertAll(
                { assert process.success               },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("kmercount - fasta - stub") {
        options "-stub"

        when {
            process {
                """
                input[0] = GUNZIP.out.gunzip
                input[1] = 11
                """
            }
        }

        then {
            assertAll(
                { assert process.success               },
                { assert snapshot(process.out).match() }
            )
        }
    }


}
