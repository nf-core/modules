nextflow_process {
    name "Test Process HIPHASE"
    script "../main.nf"
    process "HIPHASE"

    tag "modules"
    tag "modules_nfcore"
    tag "hiphase"

    test("homo_sapiens - pacbio - [bam, bai, snv_vcf, snv_csi, [], [], []] - fasta - fai - false - tsv") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/bam/NA03697B2_downsampled.pbmm2.repeats.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/bam/NA03697B2_downsampled.pbmm2.repeats.bam.bai', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/vcf/NA03697B2_new.pbmm2.repeats.vcf.gz', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/vcf/NA03697B2_new.pbmm2.repeats.vcf.gz.csi', checkIfExists: true),
                    [],
                    [],
                    []
                ]
                input[1] = [
                    [ id:'genome' ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome3.fasta', checkIfExists: true),
                    []
                ]
                input[2] = false
                input[3] = false
                input[4] = false
                input[5] = false
                input[6] = false
                input[7] = 'tsv'
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }

    }

    test("homo_sapiens - pacbio - [bam, bai, snv_vcf, snv_csi, [], [], []] - fasta - fai - true - tsv") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/bam/NA03697B2_downsampled.pbmm2.repeats.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/bam/NA03697B2_downsampled.pbmm2.repeats.bam.bai', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/vcf/NA03697B2_new.pbmm2.repeats.vcf.gz', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/vcf/NA03697B2_new.pbmm2.repeats.vcf.gz.csi', checkIfExists: true),
                    [],
                    [],
                    []
                ]
                input[1] = [
                    [ id:'genome' ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome3.fasta', checkIfExists: true),
                    []
                ]
                input[2] = true
                input[3] = true
                input[4] = true
                input[5] = true
                input[6] = true
                input[7] = 'tsv'
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    process.out.vcfs,
                    process.out.vcfs_indexes,
                    process.out.sv_vcfs,
                    process.out.sv_vcfs_indexes,
                    file(process.out.summary_tsv[0][1]).name,
                    file(process.out.blocks_tsv[0][1]).name,
                    file(process.out.stats_tsv[0][1]).name,
                    file(process.out.haplotag_tsv[0][1]).name,
                    process.out.bams,
                    process.out.bams_indexes,
                    process.out.findAll { key, val -> key.startsWith("versions")}
                ).match() }
            )
        }

    }

    test("homo_sapiens - pacbio - [bam, bai, snv_vcf, snv_csi, [], [], []] - fasta - fai - true - csv") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/bam/NA03697B2_downsampled.pbmm2.repeats.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/bam/NA03697B2_downsampled.pbmm2.repeats.bam.bai', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/vcf/NA03697B2_new.pbmm2.repeats.vcf.gz', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/pacbio/vcf/NA03697B2_new.pbmm2.repeats.vcf.gz.csi', checkIfExists: true),
                    [],
                    [],
                    []
                ]
                input[1] = [
                    [ id:'genome' ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome3.fasta', checkIfExists: true),
                    []
                ]
                input[2] = true
                input[3] = true // produces empty file
                input[4] = true // produces empty file
                input[5] = true // produces empty file
                input[6] = true // produces empty file
                input[7] = 'csv'
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    process.out.vcfs,
                    process.out.vcfs_indexes,
                    process.out.sv_vcfs,
                    process.out.sv_vcfs_indexes,
                    file(process.out.summary_csv[0][1]).name,
                    file(process.out.blocks_csv[0][1]).name,
                    file(process.out.stats_csv[0][1]).name,
                    file(process.out.haplotag_csv[0][1]).name,
                    process.out.bams,
                    process.out.bams_indexes,
                    process.out.findAll { key, val -> key.startsWith("versions")}
                ).match() }
            )
        }

    }

