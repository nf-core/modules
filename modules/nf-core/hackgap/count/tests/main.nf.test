nextflow_process {

    name "Test Process HACKGAP_COUNT"
    script "../main.nf"
    process "HACKGAP_COUNT"
    config "./nextflow.config"

    tag "modules"
    tag "modules_nfcore"
    tag "hackgap"
    tag "hackgap/count"

    test("sarscov2 - fasta - continuous k-mer") {

        when {
            params {
                module_args = '-k 5 -n 1000'
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(
                    path(process.out.hash[0][1]).getFileName().toString(),
                    path(process.out.info[0][1]).getFileName().toString(),
                    process.out.findAll { key, val -> key.startsWith("versions") }
                    ).match() 
                }
            )
        }

    }

    test("sarscov2 - fasta - gapped k-mer") {

        when {
            params {
                module_args = '--mask "##_##" -n 1000'
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(
                    path(process.out.hash[0][1]).getFileName().toString(),
                    path(process.out.info[0][1]).getFileName().toString(),
                    process.out.findAll { key, val -> key.startsWith("versions") }
                    ).match() 
                }
            )
        }

    }

    test("sarscov2 - fasta - stub") {

        options "-stub"

        when {
            params {
                module_args = '-k 5 -n 1000'
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }

    }

}
