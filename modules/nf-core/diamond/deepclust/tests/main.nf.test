nextflow_process {

    name "Test Process DIAMOND_DEEPCLUST"
    script "../main.nf"
    process "DIAMOND_DEEPCLUST"

    tag "modules"
    tag "modules_nfcore"
    tag "diamond"
    tag "diamond/deepclust"

    test("human - fasta") {
        when {
            process {
                """
                input[0] = [
                    [ id:'human' ], // meta map
                    file(params.modules_testdata_base_path + 'proteomics/database/UP000005640_9606.fasta', checkIfExists: true)
                ]
                input[1] = false
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    path(process.out.clusters[0][1]).readLines().size(),
                    process.out.findAll { key, val -> key.startsWith("versions") }
                ).match() }
            )
        }
    }

    test("human - fasta - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'human' ], // meta map
                    file(params.modules_testdata_base_path + 'proteomics/database/UP000005640_9606.fasta', checkIfExists: true)
                ]
                input[1] = false
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }

    test("human - fasta - save_aln - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'human' ], // meta map
                    file(params.modules_testdata_base_path + 'proteomics/database/UP000005640_9606.fasta', checkIfExists: true)
                ]
                input[1] = true
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }
}
