params {
    modules_testdata_base_path = System.getenv("NF_MODULES_TESTDATA_BASE_PATH") ?: "https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/"
}

docker {
    enabled    = true
    runOptions = '-u $(id -u):$(id -g) --platform=linux/amd64'
}

process {
    withName: "HDL_RG" {
        ext.args = "N0 = 0"
    }
}
