nextflow_process {

    name "Test Process BLOBTK_CREATE"
    script "../main.nf"
    process "BLOBTK_CREATE"

    tag "modules"
    tag "modules_nfcore"
    tag "blobtk"
    tag "blobtk/create"

    test("bacteroides fragilis - fasta and full_table") {

        when {

            process {
                """
                input[0] = Channel.of(
                    [
                        [ id:'test' ], // meta map
                        file(params.modules_testdata_base_path + "genomics/prokaryotes/bacteroides_fragilis/genome/genome.fna.gz", checkIfExists: true),
                        file(params.modules_testdata_base_path + "genomics/prokaryotes/bacteroides_fragilis/busco/bacteria_odb10/full_table.tsv", checkIfExists: true),
                    ]
                )

                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("bacteroides fragilis - fasta") {

        when {

            process {
                """
                input[0] = Channel.of(
                    [
                        [ id:'test' ], // meta map
                        file(params.modules_testdata_base_path + "genomics/prokaryotes/bacteroides_fragilis/genome/genome.fna.gz", checkIfExists: true),
                        [],
                    ]
                )

                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("bacteroides fragilis - fasta - stub") {

        options "-stub"

        when {

            params {
                blobtk_args = "-s 1000"
            }

            process {
                """
                input[0] = Channel.of(
                    [
                        [ id:'test' ], // meta map
                        file(params.modules_testdata_base_path + "genomics/prokaryotes/bacteroides_fragilis/genome/genome.fna.gz", checkIfExists: true),
                        [],
                    ]
                )
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
