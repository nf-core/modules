nextflow_process {

    name "Test Process CUSTOM_ORFNORMALISE"
    script "../main.nf"
    process "CUSTOM_ORFNORMALISE"

    tag "modules"
    tag "modules_nfcore"
    tag "custom"
    tag "custom/orfnormalise"

    test("homo_sapiens [chr20] - ribocode") {

        when {
            process {
                """
                input[0] = channel.of([
                    [id: 'sample1'],
                    file('https://raw.githubusercontent.com/pinin4fjords/test-datasets/add-orf-prediction-fixtures/data/genomics/homo_sapiens/riboseq_expression/orf_predictions/sample1.ribocode.txt', checkIfExists: true),
                    'ribocode'
                ])
                input[1] = channel.of([
                    [id: 'reference'],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/riboseq_expression/Homo_sapiens.GRCh38.111_chr20.gtf', checkIfExists: true)
                ])
                """
            }
        }

        then {
            def all_lines = path(process.out.tsv[0][1]).text.readLines()
            def lines = all_lines.findAll { !it.startsWith('#') }
            def cols  = lines[0].split('\t') as List
            def rows  = lines.drop(1).collect { it.split('\t') }
            def parser_columns_line = all_lines.find { it.startsWith('# parser_columns:') }
            def aa    = cols.indexOf('aa_length')
            def score = cols.indexOf('score')
            def cls   = cols.indexOf('orf_class')
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                { assert rows.size() > 0 },
                { assert rows.every { it[aa].toInteger() > 0 } },
                { assert rows.every { it[score] && it[score] != '' } },
                { assert rows.collect { it[cls] }.toSet().any { it != 'other' } },
                { assert parser_columns_line != null },
                { assert parser_columns_line.contains('caller=ribocode') },
                { assert parser_columns_line.contains('score=pval_combined') }
            )
        }
    }

    test("homo_sapiens [chr20] - ribotish") {

        when {
            process {
                """
                input[0] = channel.of([
                    [id: 'sample1'],
                    file('https://raw.githubusercontent.com/pinin4fjords/test-datasets/add-orf-prediction-fixtures/data/genomics/homo_sapiens/riboseq_expression/orf_predictions/sample1.ribotish.pred.txt', checkIfExists: true),
                    'ribotish'
                ])
                input[1] = channel.of([
                    [id: 'reference'],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/riboseq_expression/Homo_sapiens.GRCh38.111_chr20.gtf', checkIfExists: true)
                ])
                """
            }
        }

        then {
            def all_lines = path(process.out.tsv[0][1]).text.readLines()
            def lines = all_lines.findAll { !it.startsWith('#') }
            def cols  = lines[0].split('\t') as List
            def rows  = lines.drop(1).collect { it.split('\t') }
            def parser_columns_line = all_lines.find { it.startsWith('# parser_columns:') }
            def aa    = cols.indexOf('aa_length')
            def score = cols.indexOf('score')
            def cls   = cols.indexOf('orf_class')
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                { assert rows.size() > 0 },
                { assert rows.every { it[aa].toInteger() > 0 } },
