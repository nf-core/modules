nextflow_process {

    name "Test Process CUSTOM_ORFNORMALISE"
    script "../main.nf"
    process "CUSTOM_ORFNORMALISE"

    tag "modules"
    tag "modules_nfcore"
    tag "custom"
    tag "custom/orfnormalise"

    test("ribocode - stub") {
        options "-stub-run"

        when {
            process {
                """
                def orfs = file('sample_X.txt')
                orfs.text = ''
                def gtf = file('reference.gtf')
                gtf.text = ''
                input[0] = Channel.of([ [id: 'sample_X', caller: 'ribocode'], orfs ])
                input[1] = Channel.of([ [id: 'reference'], gtf ])
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("ribotish - stub") {
        options "-stub-run"

        when {
            process {
                """
