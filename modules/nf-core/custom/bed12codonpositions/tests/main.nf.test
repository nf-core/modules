nextflow_process {

    name "Test Process CUSTOM_BED12CODONPOSITIONS"
    script "../main.nf"
    process "CUSTOM_BED12CODONPOSITIONS"

    tag "modules"
    tag "modules_nfcore"
    tag "custom"
    tag "custom/bed12codonpositions"

    test("sarscov2 - bed12 - default") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/bed/test.bed12', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    process.out.bed,
                    process.out.findAll { key, val -> key.startsWith('versions') }
                ).match() }
            )
        }
    }

    test("sarscov2 - bed12 - width 3") {

        config "./nextflow.config"

        when {
            process {
                """
                input[0] = [
                    [ id:'test_width3' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/bed/test.bed12', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    process.out.bed,
                    process.out.findAll { key, val -> key.startsWith('versions') }
                ).match() }
            )
        }
    }

    test("sarscov2 - bed12 - stub") {

        options '-stub'

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/bed/test.bed12', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
