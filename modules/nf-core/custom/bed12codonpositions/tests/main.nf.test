nextflow_process {

    name "Test Process CUSTOM_BED12CODONPOSITIONS"
    script "../main.nf"
    process "CUSTOM_BED12CODONPOSITIONS"
    config "./nextflow.config"

    tag "modules"
    tag "modules_nfcore"
    tag "custom"
    tag "custom/bed12codonpositions"

    test("sarscov2 - bed12 - default") {

        when {
            params {
                module_args = ''
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/bed/test.bed12', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    process.out.bed,
                    process.out.findAll { key, val -> key.startsWith('versions') }
                ).match() }
            )
        }
    }

    test("sarscov2 - bed12 - width 3") {

        when {
            params {
                module_args = '--width 3'
            }
            process {
                """
                input[0] = [
                    [ id:'test_width3' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/bed/test.bed12', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    process.out.bed,
                    process.out.findAll { key, val -> key.startsWith('versions') }
                ).match() }
            )
        }
    }

    test("sarscov2 - bed12 - frame 1") {

        when {
            params {
                module_args = '--frame 1'
            }
            process {
                """
                input[0] = [
                    [ id:'test_frame1' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/bed/test.bed12', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    process.out.bed,
                    process.out.findAll { key, val -> key.startsWith('versions') }
                ).match() }
            )
        }
    }

    test("intron - bed12 - default") {

        when {
            params {
                module_args = ''
            }
            process {
                """
                def intron_bed = new File('intron.bed12')
                intron_bed.text = '''chr_test\t100\t210\tplus_2exon\t10\t+\t100\t210\t0\t2\t10,10\t0,100
chr_test\t300\t410\tminus_2exon\t20\t-\t300\t410\t0\t2\t10,10\t0,100
'''
                input[0] = [
                    [ id:'test_intron' ],
                    file(intron_bed, checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    process.out.bed,
                    process.out.findAll { key, val -> key.startsWith('versions') }
                ).match() }
            )
        }
    }

    test("intron - bed12 - width 3") {

        when {
            params {
                module_args = '--width 3'
            }
            process {
                """
                def intron_bed = new File('intron_w3.bed12')
                intron_bed.text = '''chr_test\t100\t210\tplus_2exon\t10\t+\t100\t210\t0\t2\t10,10\t0,100
chr_test\t300\t410\tminus_2exon\t20\t-\t300\t410\t0\t2\t10,10\t0,100
'''
                input[0] = [
                    [ id:'test_intron_w3' ],
                    file(intron_bed, checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    process.out.bed,
                    process.out.findAll { key, val -> key.startsWith('versions') }
                ).match() }
            )
        }
    }

    test("3 single-nt blocks - keep duplicates") {

        when {
            params {
                module_args = '--width 2 --step 1 --keep-duplicates'
            }
            process {
                """
                def dup_bed = new File('dup.bed12')
                dup_bed.text = 'chr_test\t100\t301\tdup_3exon\t50\t+\t100\t301\t0\t3\t1,1,1\t0,100,200\\n'
                input[0] = [
                    [ id:'test_keepdup' ],
                    file(dup_bed, checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    process.out.bed,
                    process.out.findAll { key, val -> key.startsWith('versions') }
                ).match() }
            )
        }
    }

    test("sarscov2 - bed12 - stub") {

        options '-stub'

        when {
            params {
                module_args = ''
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/bed/test.bed12', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
