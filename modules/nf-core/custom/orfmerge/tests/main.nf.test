nextflow_process {

    name "Test Process CUSTOM_ORFMERGE"
    script "../main.nf"
    process "CUSTOM_ORFMERGE"

    tag "modules"
    tag "modules_nfcore"
    tag "custom"
    tag "custom/orfmerge"

    test("synthetic - stub") {
        options "-stub-run"

        when {
            process {
                """
                def bed = file('sample_X.ribotish.normalised.bed12')
                bed.text = ''
                def tsv = file('sample_X.ribotish.normalised.tsv')
                tsv.text = ''
                input[0] = Channel.of([ [id: 'allsamples'], [bed], [tsv] ])
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("empty inputs exercise template") {

        when {
            process {
                """
                def bed = file('sample_X.ribotish.normalised.bed12')
                bed.text = ''
                def tsv = file('sample_X.ribotish.normalised.tsv')
                tsv.text = ''
                input[0] = Channel.of([ [id: 'allsamples'], [bed], [tsv] ])
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
