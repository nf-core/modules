nextflow_process {

    name "Test Process CUSTOM_ORFMERGE"
    script "../main.nf"
    process "CUSTOM_ORFMERGE"

    tag "modules"
    tag "modules_nfcore"
    tag "custom"
    tag "custom/orfmerge"
    tag "custom/orfnormalise"

    setup {
        run("CUSTOM_ORFNORMALISE", alias: "CUSTOM_ORFNORMALISE_RIBOTISH") {
            script "../../orfnormalise/main.nf"
            config "./setup_prefix.config"
            process {
                """
                input[0] = channel.of([
                    [id: 'sample1', caller: 'ribotish'],
                    file('https://raw.githubusercontent.com/pinin4fjords/test-datasets/add-orf-prediction-fixtures/data/genomics/homo_sapiens/riboseq_expression/orf_predictions/sample1.ribotish.pred.txt', checkIfExists: true),
                    'ribotish'
                ])
                input[1] = channel.of([
                    [id: 'reference'],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/riboseq_expression/Homo_sapiens.GRCh38.111_chr20.gtf', checkIfExists: true)
                ])
                """
            }
        }
        run("CUSTOM_ORFNORMALISE", alias: "CUSTOM_ORFNORMALISE_RIBOCODE") {
            script "../../orfnormalise/main.nf"
            config "./setup_prefix.config"
            process {
                """
                input[0] = channel.of([
                    [id: 'sample1', caller: 'ribocode'],
                    file('https://raw.githubusercontent.com/pinin4fjords/test-datasets/add-orf-prediction-fixtures/data/genomics/homo_sapiens/riboseq_expression/orf_predictions/sample1.ribocode.txt', checkIfExists: true),
                    'ribocode'
                ])
                input[1] = channel.of([
                    [id: 'reference'],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/riboseq_expression/Homo_sapiens.GRCh38.111_chr20.gtf', checkIfExists: true)
                ])
                """
            }
        }
        run("CUSTOM_ORFNORMALISE", alias: "CUSTOM_ORFNORMALISE_RIBOTISH_SAMPLE2") {
            script "../../orfnormalise/main.nf"
            config "./setup_prefix.config"
            process {
                """
                input[0] = channel.of([
                    [id: 'sample2', caller: 'ribotish'],
                    file('https://raw.githubusercontent.com/pinin4fjords/test-datasets/add-orf-prediction-fixtures/data/genomics/homo_sapiens/riboseq_expression/orf_predictions/sample1.ribotish.pred.txt', checkIfExists: true),
                    'ribotish'
                ])
                input[1] = channel.of([
                    [id: 'reference'],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/riboseq_expression/Homo_sapiens.GRCh38.111_chr20.gtf', checkIfExists: true)
                ])
                """
            }
        }
    }

    test("homo_sapiens [chr20] - ribotish + ribocode") {

        when {
            process {
                """
                ch_beds = CUSTOM_ORFNORMALISE_RIBOTISH.out.bed12
                    .mix(CUSTOM_ORFNORMALISE_RIBOCODE.out.bed12)
                    .mix(CUSTOM_ORFNORMALISE_RIBOTISH_SAMPLE2.out.bed12)
                    .map { _meta, bed -> bed }
                    .collect()
                    .map { beds -> [ 'cohort', beds ] }
                ch_tsvs = CUSTOM_ORFNORMALISE_RIBOTISH.out.tsv
                    .mix(CUSTOM_ORFNORMALISE_RIBOCODE.out.tsv)
                    .mix(CUSTOM_ORFNORMALISE_RIBOTISH_SAMPLE2.out.tsv)
                    .map { _meta, tsv -> tsv }
                    .collect()
                    .map { tsvs -> [ 'cohort', tsvs ] }
                input[0] = ch_beds
                    .combine(ch_tsvs, by: 0)
                    .map { _k, beds, tsvs -> [ [id: 'cohort'], beds, tsvs ] }
                """
            }
        }

        then {
            def lines = path(process.out.catalogue_tsv[0][1]).text.readLines()
            def cols  = lines[0].split('\t') as List
            def rows  = lines.drop(1).collect { it.split('\t') }
            def aa             = cols.indexOf('aa_length')
            def cls            = cols.indexOf('orf_class')
            def called_ribotish = cols.indexOf('called_by_ribotish')
            def called_ribocode = cols.indexOf('called_by_ribocode')
            def score_ribotish  = cols.indexOf('score_ribotish')
            def score_ribocode  = cols.indexOf('score_ribocode')
            def n_samples       = cols.indexOf('n_samples')
            def samples         = cols.indexOf('samples')
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
                { assert rows.size() > 0 },
                { assert rows.every { it[aa].toInteger() > 0 } },
                // Each row must come from at least one caller; the
                // catalogue must include calls from both callers exercised
                // in setup.
                { assert rows.every { it[called_ribotish] == '1' || it[called_ribocode] == '1' } },
                { assert rows.any { it[called_ribotish] == '1' } },
                { assert rows.any { it[called_ribocode] == '1' } },
                // For rows where a caller contributed, the score column must
                // carry a numeric value (catches the case where a parser
                // bug populates `1` indicator but no real score).
                { assert rows.findAll { it[called_ribotish] == '1' }.every { it[score_ribotish] && it[score_ribotish] != '' } },
                { assert rows.findAll { it[called_ribocode] == '1' }.every { it[score_ribocode] && it[score_ribocode] != '' } },
                // Class distribution must not collapse to one bucket.
                { assert rows.collect { it[cls] }.toSet().size() >= 1 },
                { assert rows.collect { it[cls] }.toSet().any { it != 'other' } },
                // Cross-sample recurrence: ribotish is run for both sample1
                // and sample2, so the shared ribotish calls must collapse to
                // one cluster recording both samples.
                { assert rows.every { it[n_samples].toInteger() >= 1 } },
                { assert rows.any { it[n_samples].toInteger() == 2 } },
                { assert rows.findAll { it[n_samples].toInteger() == 2 }.every { it[samples] == 'sample1,sample2' } }
            )
        }
    }

}
