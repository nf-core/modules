                    """
                    input[0] = [ [id: 'samples1'], file("${outputDir}/mock_tpm_1.txt") ]
                    input[1] = SUPPA_GENERATEEVENTS.out.events
                    input[2] = 0
                    """
                }
            }

            run("SUPPA_PSIPEREVENT", alias: "SUPPA_PSIPEREVENT_COND2") {
                tag "suppa/psiperevent"
                script "../../psiperevent/main.nf"
                process {
                    """
                    input[0] = [ [id: 'samples2'], file("${outputDir}/mock_tpm_2.txt") ]
                    input[1] = SUPPA_GENERATEEVENTS.out.events
                    input[2] = 0
                    """
                }
            }
        }
        when {
            process {
                """
                input[0] = SUPPA_GENERATEEVENTS.out.events.map { meta, events -> [ [ id: 'test_SE' ], events ] }
                input[1] = SUPPA_PSIPEREVENT_COND1.out.psi.map { meta, psi -> [ [ id: 'samples1' ], 'condition1', file("${outputDir}/mock_tpm_1.txt"), psi ] }
                input[2] = SUPPA_PSIPEREVENT_COND2.out.psi.map { meta, psi -> [ [ id: 'samples2' ], 'condition2', file("${outputDir}/mock_tpm_2.txt"), psi ] }
                input[3] = 'empirical'
                input[4] = 1000
                input[5] = 5
                input[6] = false
                input[7] = false
                input[8] = 0.05
                input[9] = false
                input[10] = false
                input[11] = false
                input[12] = 0
                input[13] = 0
                """
            }
        }

        then {
            assert process.success
            assertAll(
                {
                    assert snapshot(
                        process.out.dpsi.collect { meta, dpsi -> file(dpsi).getName().toString() },
                        process.out.psivec.collect { meta, psivec -> file(psivec).getName().toString() },
                    ).match()
                }
            )
        }
    }

