    test("human - ioi") {
        setup {

            //
            // Make mock expression files for two conditions with 2 samples using the same transcripts as in the events file
            //
            def transcripts = [
                "ENST00000614229.4", "ENST00000400566.6", "ENST00000658863.1",
                "ENST00000635225.1", "ENST00000635621.1", "ENST00000449602.2",
                "ENST00000654045.1", "ENST00000669763.1", "ENST00000660967.1",
                "ENST00000339775.10", "ENST00000284881.9", "ENST00000671660.1",
                "ENST00000656151.1", "ENST00000656404.1", "ENST00000666665.1",
                "ENST00000400094.5", "ENST00000348990.9", "ENST00000346798.8",
