nextflow_process {

    name "Test Process SEGUL_ALIGNTRIM"
    script "../main.nf"
    process "SEGUL_ALIGNTRIM"
    config "./nextflow.config"

    tag "modules"
    tag "modules_nfcore"
    tag "segul"
    tag "segul/aligntrim"
    tag "gunzip"

    setup {
        run("GUNZIP") {
            script "../../../gunzip/main.nf"
            process {
                """
                input[0] = [
                    [ id:'PF14720' ],
                    file(params.modules_testdata_base_path + 'delete_me/hmmer/PF14720_seed.alnfaa.gz', checkIfExists: true)
                ]
                """
            }
        }
    }

    test("PF14720 - aa - default missing data") {
        when {
            params {
                module_args = "--input-format fasta"
            }
            process {
                """
                input[0] = GUNZIP.out.gunzip
                input[1] = "aa"
                """
            }
        }

        then {
            assert process.success
            assertAll(
               { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }

    test("PF14720 - aa - missing data 0.3 - nexus output") {
        when {
            params {
                module_args = "--input-format fasta --output-format nexus --missing-data 0.3"
            }
            process {
                """
                input[0] = GUNZIP.out.gunzip
                input[1] = "aa"
                """
            }
        }

        then {
            assert process.success
            assertAll(
               { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }

    test("PF14720 - aa - parsimony informative sites") {
        when {
            params {
                module_args = "--input-format fasta --pinf 1"
            }
            process {
                """
                input[0] = GUNZIP.out.gunzip
                input[1] = "aa"
                """
            }
        }

        then {
            assert process.success
            assertAll(
               { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }

    test("PF14720 - aa - stub") {
        options "-stub"

        when {
            params {
                module_args = ""
            }
            process {
                """
                input[0] = GUNZIP.out.gunzip
                input[1] = []
                """
            }
        }

        then {
            assert process.success
            assertAll(
               { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }
}
