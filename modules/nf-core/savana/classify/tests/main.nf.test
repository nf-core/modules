nextflow_process {

    name "Test Process SAVANA_CLASSIFY"
    script "../main.nf"
    process "SAVANA_CLASSIFY"

    tag "modules"
    tag "modules_nfcore"
    tag "savana"
    tag "savana/classify"

    test("homo_sapiens - vcf.gz") {

        when {
            process {
                """

                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/vcf/chr21/simulated_sv.vcf.gz', checkIfExists: true),
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(
                    process.out,
                    path(process.out.classified_vcf.get(0).get(1)).vcf.summary,
                    path(process.out.somatic_vcf.get(0).get(1)).vcf.summary,
                    path(process.out.germline_vcf.get(0).get(1)).vcf.summary,
                    path(process.out.somatic_bedpe.get(0).get(1)).name,
                    path(process.out.legacy_vcfs.get(0).get(1)).vcf.summary,
                    process.out.findAll { key, val -> key.startsWith('versions') }
                ).match() }
            )
        }

    }

    test("homo_sapiens - vcf.gz - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/vcf/chr21/simulated_sv.vcf.gz', checkIfExists: true),
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }

    }

}
