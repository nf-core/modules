nextflow_process {

    name "Test Process SOUPX"
    script "../main.nf"
    process "SOUPX"

    tag "modules"
    tag "modules_nfcore"
    tag "soupx"

    test("scdownstream - h5ad") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_filtered_matrix.h5ad', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_raw_matrix.h5ad', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                // h5ad is a binary HDF5 file whose bytes change between runs
                // (write timestamps, Leiden non-determinism). Check presence +
                // non-empty size instead of snapshotting the file.
                { assert path(process.out.h5ad.get(0).get(1)).exists() },
                { assert path(process.out.h5ad.get(0).get(1)).size() > 0 },
                { assert snapshot(
                    process.out.versions,
                    file(process.out.h5ad[0][1]).name
                ).match() }
            )
        }

    }

    test("scdownstream - h5ad - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_filtered_matrix.h5ad', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scrnaseq/h5ad/SRR28679756_raw_matrix.h5ad', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

}
