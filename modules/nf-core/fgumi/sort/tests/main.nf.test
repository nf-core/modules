nextflow_process {

    name "Test Process FGUMI_SORT"
    script "../main.nf"
    process "FGUMI_SORT"
    config "./nextflow.config"

    tag "modules"
    tag "modules_nfcore"
    tag "fgumi"
    tag "fgumi/sort"

    test("bam - coordinate sort - index") {

        when {
            params {
                fgumi_args = '--order coordinate --write-index'
            }
            process {
                """
                input[0] = [
                            [ id:'test', single_end:false ],
                            file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/umi/test.paired_end.duplex_umi_mapped.bam', checkIfExists: true)
                        ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(
                    process.out,
                    path(process.out.versions[0]).yaml
                ).match() }
            )
        }
    }

    test("bam - queryname sort - no index") {

        when {
            params {
                fgumi_args = '--order queryname'
            }
            process {
                """
                input[0] = [
                            [ id:'test', single_end:false ],
                            file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/umi/test.paired_end.duplex_umi_mapped.bam', checkIfExists: true)
                        ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(
                    process.out,
                    path(process.out.versions[0]).yaml
                ).match() }
            )
        }
    }

    test("bam - coordinate sort - stub") {

        options "-stub"

        when {
            params {
                fgumi_args = '--order coordinate --write-index'
            }
            process {
                """
                input[0] = [
                            [ id:'test', single_end:false ],
                            file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/umi/test.paired_end.duplex_umi_mapped.bam', checkIfExists: true)
                        ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(
                    process.out,
                    path(process.out.versions[0]).yaml
                ).match() }
            )
        }

    }

}
