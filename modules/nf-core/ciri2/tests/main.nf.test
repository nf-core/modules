nextflow_process {

    name "Test Process CIRI2"
    script "../main.nf"
    process "CIRI2"

    test("homo_sapiens - sam - pairedend") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test', single_end: false ],
                    file("/home/razmia/nf-core-modules/modules/nf-core/ciri2/tests/test_data/sample.sam", checkIfExists: true)
                ]
                input[1] = file("/home/razmia/nf-core-modules/modules/nf-core/ciri2/tests/test_data/chr1.fa")
                input[2] = []
                input[3] = []
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    file(process.out.circrna[0][1]).name,
                    process.out.logfile ? file(process.out.logfile[0][1]).name : null
                ).match() }
            )
        }
    }
}
