nextflow_process {

    config "./nextflow.config"

    name "Test Process KNOTANNOTSV"
    script "../main.nf"
    process "KNOTANNOTSV"

    tag "modules"
    tag "modules_nfcore"
    tag "knotannotsv"

    test("homo_sapiens - annotsv_tsv, knot_out_xl - HTML output") {

        when {
            params {
                module_args = "--genomeBuild hg38"
                module_prefix = "knot"
            }

            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/illumina/tsv/sv_query.tsv", checkIfExists: true),
                    false
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(path(process.out.html[0][1]).readLines().size()).match("test_HTML_output_lines_count") },
                { assert snapshot(process.out.findAll { key, val -> key.startsWith('versions') }).match() }
            )
        }
    }

    test("homo_sapiens - annotsv_tsv, knot_out_xl - XLSM output") {

        when {
            params {
                module_args = "--genomeBuild hg38"
                module_prefix = "knot"
            }

            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/illumina/tsv/sv_query.tsv", checkIfExists: true),
                    true
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(file(process.out.xl[0][1]).length() >= 89000).match("test_Excel_output_min_size") },
                { assert snapshot(process.out.findAll { key, val -> key.startsWith('versions') }).match() }
            )
        }
    }

    test("homo_sapiens - annotsv_tsv, knot_out_xl - stub") {

        options "-stub"

        when {
            params {
                module_args = "--genomeBuild hg38"
                module_prefix = "knot"
            }

            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/illumina/tsv/sv_query.tsv", checkIfExists: true),
                    false
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
