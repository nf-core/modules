nextflow_process {

    config "./nextflow.config"

    name "Test Process KNOTANNOTSV"
    script "../main.nf"
    process "KNOTANNOTSV"

    tag "modules"
    tag "modules_nfcore"
    tag "knotannotsv"

    test("homo_sapiens - annotsv_tsv, knot_out_xl - HTML output") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file('https://github.com/nf-core/test-datasets/raw/1657be40f475956306087cb699425ddba4420f2a/data/genomics/homo_sapiens/illumina/tsv/sv_query.tsv', checkIfExists: true)
                ]
                input[1] = false
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out.findAll { key, val -> key.startsWith('versions') }).match() }
            )
        }
    }

    test("homo_sapiens - annotsv_tsv, knot_out_xl - XLSM output") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file('https://github.com/nf-core/test-datasets/raw/1657be40f475956306087cb699425ddba4420f2a/data/genomics/homo_sapiens/illumina/tsv/sv_query.tsv', checkIfExists: true)
                ]
                input[1] = true
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out.findAll { key, val -> key.startsWith('versions') }).match() }
            )
        }
    }

    test("homo_sapiens - annotsv_tsv, knot_out_xl - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file('annots_tsv', checkIfExists: false)
                ]
                input[1] = false
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
