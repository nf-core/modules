nextflow_process {
    name "Test Process CHECKM_LINEAGEWF"
    script "../main.nf"
    process "CHECKM_LINEAGEWF"

    tag "modules"
    tag "modules_nfcore"
    tag "checkm"
    tag "checkm/lineagewf"
    tag "untar"

    test("checkm - lineage_wf") {
        setup {
            run("UNTAR") {
                script "modules/nf-core/untar/main.nf"
                process {
                    """
                    input[0] = [ [], file('https://data.ace.uq.edu.au/public/CheckM_databases/checkm_data_2015_01_16.tar.gz', checkIfExists: true) ]
                    """
                }
            }
        }

        when {
            process {
                """
                input[0] = [
                    [ id:'test', single_end:false ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fasta/contigs.fasta', checkIfExists: true)
                ]
                input[1] = 'fasta'
                input[2] = UNTAR.out.untar.map{_meta, db -> [db]}
                """
            }
        }

        then {
            assert process.success
            assert file(process.out.checkm_output[0][1]).list().find { file(it).name == "checkm.log" }
            assert snapshot(
                path(process.out.marker_file[0][1]).readLines().any{it.contains("PF00312.17")},
                process.out.checkm_tsv,
                process.out.findAll { key, val -> key.startsWith('versions') }
                ).match()
        }

    }

    test("stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test', single_end:false ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fasta/contigs.fasta', checkIfExists: true)
                ]
                input[1] = 'fasta'
                input[2] = []
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
        }

    }
}
