                    file(params.test_data['sarscov2']['pacbio']['test_fastq_gz'], checkIfExists: true),
                    file(params.test_data['sarscov2']['nanopore']['test_fastq_gz'], checkIfExists: true),
                    [],  // no other reads
                    []   // no reference genome
                ]
