    test("sarscov2 - illumina - paired_end - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test', single_end:false ],
                    [
                        file(params.test_data['sarscov2']['illumina']['test_1_fastq_gz'], checkIfExists: true),
                        file(params.test_data['sarscov2']['illumina']['test_2_fastq_gz'], checkIfExists: true)
                    ],
                    [],  // no jump reads
                    [],  // no pacbio
                    [],  // no nanopore
                    [],  // no other reads
                    []   // no reference genome
                ]
                input[1] = 500   // fragment_mean
                input[2] = 50    // fragment_stdev
                input[3] = 0     // jump_mean (not used)
                input[4] = 0     // jump_stdev (not used)
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
