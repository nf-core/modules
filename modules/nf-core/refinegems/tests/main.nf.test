nextflow_process {

    name "Test Process REFINEGEMS"
    script "../main.nf"
    process "REFINEGEMS"

    tag "modules"
    tag "modules_nfcore"
    tag "refinegems"

    test("test-refinegems-stub") {
        options '-stub'

        when {
            process {
                """
                input[0] = [ [ id:'test', single_end:false ], 'refinegems' ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

}
