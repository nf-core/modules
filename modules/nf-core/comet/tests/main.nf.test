nextflow_process {

    name "Test Process COMET"
    script "../main.nf"
    process "COMET"

    config "./nextflow.config"
    
    tag "modules"
    tag "modules_nfcore"
    tag "comet"
    tag "thermorawfileparser"


    test("comet - mzml - test") {
        setup {
            // we use thermorawfileparser to convert a provided raw file to mzML first
            run("THERMORAWFILEPARSER") {
                script "../../thermorawfileparser/main.nf"
                process {
                    """
                    input[0] = [
                        [ id:'test'],
                        file(params.modules_testdata_base_path + 'proteomics/msspectra/OVEMB150205_12.raw', checkIfExists: true),
                    ]
                    """
                }
            }
        }

        when {
            process {
                """
                input[0] = THERMORAWFILEPARSER.out.spectra.map { meta, mzml ->
                    [
                        meta,
                        mzml,
                        file(params.modules_testdata_base_path + 'proteomics/database/yeast_UPS.fasta', checkIfExists: true),
                        file('https://uwpr.github.io/Comet/parameters/parameters_202601/comet.params.high-high', checkIfExists: true),
                    ]
                }
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(path(process.out.txt[0][1]).readLines().drop(1).take(50)).match() }
            )
        }
    }

    test("comet - mzml - test - stub") {

        options "-stub"

        setup {
            // we use thermorawfileparser to convert a provided raw file to mzML first
            run("THERMORAWFILEPARSER") {
                script "../../thermorawfileparser/main.nf"
                process {
                    """
                    input[0] = [
                        [ id:'test'],
                        file(params.modules_testdata_base_path + 'proteomics/msspectra/OVEMB150205_12.raw', checkIfExists: true),
                    ]
                    """
                }
            }
        }

        when {
            process {
                """
                input[0] = THERMORAWFILEPARSER.out.spectra.map { meta, mzml ->
                    [
                        meta,
                        mzml,
                        file(params.modules_testdata_base_path + 'proteomics/database/yeast_UPS.fasta', checkIfExists: true),
                        file('https://uwpr.github.io/Comet/parameters/parameters_202601/comet.params.high-high', checkIfExists: true),
                    ]
                }
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }

    }

}
