nextflow_process {

    name "Test Process COMET"
    script "../main.nf"
    process "COMET"

    tag "modules"
    tag "modules_nfcore"
    tag "comet"

    test("comet - mzml - test") {

        when {
            process {
                """
                input[0] =  [
                    [ id:'test'],
                    file(params.modules_testdata_base_path + 'proteomics/msspectra/OVEMB150205_12.mzML', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'proteomics/database/yeast_UPS.fasta', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'proteomics/parameter/OVEMB150205.comet.params', checkIfExists: true),
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(path(process.out.txt[0][1]).readLines().drop(1).take(50)).match() }
            )
        }
    }

    test("comet - mzml - test - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] =  [
                    [ id:'test'],
                    file(params.modules_testdata_base_path + 'proteomics/msspectra/OVEMB150205_12.mzML', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'proteomics/database/yeast_UPS.fasta', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'proteomics/parameter/OVEMB150205.comet.params', checkIfExists: true),
                ]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }

    }

}
