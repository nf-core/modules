nextflow_process {

    name "Test Process RAMI2D_TRANSFORM"
    script "../main.nf"
    process "RAMI2D_TRANSFORM"

    tag "modules"
    tag "modules_nfcore"
    tag "rami2d"
    tag "rami2d/transform"
    tag "rami2d/register"

    test("imf_and_he ome_tif stub") {

        options "-stub"
        config "./nextflow.config"

        when {
            process {
                """
                fullres_trf = Channel.of("mock").collectFile(name: "mock_qc_dir/fullres_trf/dummy.txt").map { it.getParent().getParent() }
                dummy_markers = Channel.of("marker_name").collectFile(name: "markers.csv", newLine: true)

                input[0] = fullres_trf.map { trf ->
                    [
                        [ id:'test_imf_he' ],
                        file('https://raw.githubusercontent.com/VictorDidier/RAMI2D/sample_data/data/imf_and_he/HE.ome.tif', checkIfExists: true),
                        trf
                    ]
                }
                input[1] = dummy_markers.map { markers ->
                    [ [ id:'test_imf_he' ], markers ]
                }
                input[2] = 0.27
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }

            )
        }
    }

    test("imf_and_he ome_tif") {

        config "./nextflow.config"

        setup {
            run("RAMI2D_REGISTER") {
                script "../../register/main.nf"

                process {
                    """
                    input[0] = [
                        [ id:'test_imf_he' ],
                        file('https://raw.githubusercontent.com/VictorDidier/RAMI2D/sample_data/data/imf_and_he/multiplexed.ome.tif', checkIfExists: true),
                        file('https://raw.githubusercontent.com/VictorDidier/RAMI2D/sample_data/data/imf_and_he/HE.ome.tif', checkIfExists: true)
                    ]
                    input[1] = 0
                    input[2] = 'h'
                    input[3] = 0.21
                    input[4] = 0.27
                    input[5] = 1
                    """
                }
            }
        }

        when {
            process {
                """
                input[0] = RAMI2D_REGISTER.out.qc_dir.map { meta, qc ->
                    [
                        meta,
                        file('https://raw.githubusercontent.com/VictorDidier/RAMI2D/sample_data/data/imf_and_he/HE.ome.tif', checkIfExists: true),
                        file("\${qc}/fullres_trf")
                    ]
                }
                input[1] = [["markers"], []]
                input[2] = 0.27
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert file(process.out.transformed_image[0][1]).exists() },
                { assert file(process.out.transformed_image[0][1]).name == "HE_transformed.ome.tif" },
                { assert snapshot(process.out.versions_rami2d).match("versions") }
            )
        }
    }
}
