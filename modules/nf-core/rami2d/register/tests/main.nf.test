nextflow_process {

    name "Test Process RAMI2D_REGISTER"
    script "../main.nf"
    process "RAMI2D_REGISTER"

    tag "modules"
    tag "modules_nfcore"
    tag "rami2d"
    tag "rami2d/register"

    test("imf_and_he - ome_tif") {

        config "./nextflow.config"

        when {
            process {
                """
                input[0] = [
                    [ id:'test_imf_he'], // meta map
                    file('https://raw.githubusercontent.com/VictorDidier/RAMI2D/sample_data/data/imf_and_he/multiplexed.ome.tif', checkIfExists: true),
                    file('https://raw.githubusercontent.com/VictorDidier/RAMI2D/sample_data/data/imf_and_he/HE.ome.tif', checkIfExists: true)
                ]
                input[1] = 0 // ifix
                input[2] = 'h' // imov
                input[3] = 0.21 // mpp_fix
                input[4] = 0.27 // mpp_mov
                input[5] = 1 // mpp_reg
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert file(process.out.registered_image[0][1]).exists() },
                { assert file(process.out.registered_image[0][1]).name == "HE_registered.ome.tif" },
                { assert file(process.out.qc_dir[0][1]).exists() },
                { assert file(process.out.qc_dir[0][1]).name == "qc" },
                { assert snapshot(process.out.versions_rami2d).match("versions") }
            )
        }
    }

    test("imf_and_he - ome_tif - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test_imf_he'], // meta map
                    file('https://raw.githubusercontent.com/VictorDidier/RAMI2D/sample_data/data/imf_and_he/multiplexed.ome.tif', checkIfExists: true),
                    file('https://raw.githubusercontent.com/VictorDidier/RAMI2D/sample_data/data/imf_and_he/HE.ome.tif', checkIfExists: true),
                ]
                input[1] = 0 // ifix
                input[2] = 'h' // imov
                input[3] = 0.21 // mpp_fix
                input[4] = 0.27 // mpp_mov
                input[5] = 1 // mpp_reg
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
