nextflow_process {

    name "Test Process GOATOOLS_FINDENRICHMENT"
    script "../main.nf"
    process "GOATOOLS_FINDENRICHMENT"

    tag "modules"
    tag "modules_nfcore"
    tag "goatools"
    tag "goatools/findenrichment"

    test("mock - [ txt, txt, gaf ], obo, []") {

        when {
            process {
                """ 
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'generic/txt/sample_genes.txt', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'generic/txt/population_genes.txt', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'generic/gene_ontology/go_annotation.gaf', checkIfExists: true)
                ]
                input[1] = file(params.modules_testdata_base_path + 'generic/obo/ontology.obo', checkIfExists: true)
                input[2] = []
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(
                    process.out
                ).match() }
            )
        }

    }

    test("mock - [ txt, txt, gaf ], obo, goslim") {

        when {
            process {
                """ 
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'generic/txt/sample_genes.txt', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'generic/txt/population_genes.txt', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'generic/gene_ontology/go_annotation.gaf', checkIfExists: true)
                ]
                input[1] = file(params.modules_testdata_base_path + 'generic/obo/ontology.obo', checkIfExists: true)
                input[2] = file(params.modules_testdata_base_path + 'generic/obo/ontology_slim.obo', checkIfExists: true)
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(
                    process.out
                ).match() }
            )
        }

    }

    test("mock - [ txt, txt, gaf ], obo, [] - stub") {

        options "-stub"

        when {
            process {
                """
                // TODO nf-core: define inputs of the process here. Example:
                
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'generic/txt/sample_genes.txt', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'generic/txt/population_genes.txt', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'generic/gene_ontology/go_annotation.gaf', checkIfExists: true)
                ]
                input[1] = file(params.modules_testdata_base_path + 'generic/obo/ontology.obo', checkIfExists: true)
                input[2] = []
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(
                    process.out
                ).match() }
            )
        }

    }

}
