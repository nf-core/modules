nextflow_process {

    name "Test Process SEQKIT_GREP"
    script "../main.nf"
    process "SEQKIT_GREP"
    config "./nextflow.config"

    tag "modules"
    tag "modules_nfcore"
    tag "seqkit"
    tag "seqkit/grep"

    test("with_file - gzipped input") {
        when {
            params {
                modules_args = ''
            }
            process {
                """
                input[0] = [
                    [ id:'test', single_end:false ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.gz', checkIfExists: true)
                ]
                input[1] = channel.of("chr22").collectFile(name: "chr22.header", newLine: true)
                input[2] = ''
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }

    test("with_file - ungzipped input") {
        when {
            params {
                modules_args = ''
            }
            process {
                """
                input[0] = [
                    [ id:'test', single_end:false ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true)
                ]
                input[1] = channel.of("chr22").collectFile(name: "chr22.header", newLine: true)
                input[2] = ''
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }

    test("with_pattern") {
        when {
            params {
                modules_args = '-p chr22'
            }
            process {
                """
                input[0] = [
                    [ id:'test', single_end:false ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true)
                ]
                input[1] = []
                input[2] = ''
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }

    test("with_file - stub") {
        options '-stub'

        when {
            params {
                modules_args = ''
            }
            process {
                """
                input[0] = [
                    [ id:'test', single_end:false ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true)
                ]
                input[1] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.header', checkIfExists: true)
                input[2] = ''
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }
}
