nextflow_process {

    name "Test Process SEQKIT_SAMPLE"
    script "../main.nf"
    process "SEQKIT_SAMPLE"

    tag "modules"
    tag "modules_nfcore"
    tag "seqkit"
    tag "seqkit/sample"

    test("sarscov2 - fastq_gz - proportion") {

        config "./nextflow.config"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    process.out.fastx,
                    process.out.versions_seqkit
                ).match() }
            )
        }

    }

    test("sarscov2 - genome_fasta - proportion") {

        config "./nextflow.config"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

    test("file_name_conflict - fail_with_error") {

        config "./nextflow.config"

        when {
            process {
                """
                input[0] = [
                    [ id:'test_1' ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert !process.success },
                { assert process.stdout.toString().contains("Input and output names are the same") }
            )
        }

    }

    test("sarscov2 - fastq_gz - proportion - stub") {

        options "-stub"
        config "./nextflow.config"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ], // meta map
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

}
