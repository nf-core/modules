nextflow_process {

    name "Test Process HIFIADAPTERFILT_DOWNLOADDB"
    script "../main.nf"
    process "HIFIADAPTERFILT_DOWNLOADDB"

    tag "modules"
    tag "modules_nfcore"
    tag "hifiadapterfilt"
    tag "hifiadapterfilt/downloaddb"

    test("hifiadapterfilt - downloaddb") {

        when {
            process {
                """
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    file(process.out.db[0]).list().sort(),
                    process.out.findAll { key, val -> key.startsWith("versions") }
                ).match() }
            )
        }

    }

    test("hifiadapterfilt - downloaddb - stub") {

        options "-stub"

        when {
            process {
                """
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }

    }

}
