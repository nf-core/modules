nextflow_process {

    name "Test Process VCFEXPRESS"
    script "../main.nf"
    process "VCFEXPRESS"

    tag "modules"
    tag "modules_nfcore"
    tag "vcfexpress"

    config "./nextflow.config"

    test("vcfexpress - vcf") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/vcf/test.vcf.gz', checkIfExists: true),
                ]

                input[1] = []
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(
                    sanitizeOutput(process.out)
                ).match() }
            )
        }

    }

    test("vcfexpress - prelude - vcf ") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/vcf/test.vcf.gz', checkIfExists: true),
                ]

                input[1] = [file('${moduleDir}/tests/prelude_test.lua')]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(
                    sanitizeOutput(process.out)
                ).match() }
            )
        }

    }

    test("vcfexpress - vcf - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/vcf/test.vcf.gz', checkIfExists: true),
                ]

                input[1] = []
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(
                    sanitizeOutput(process.out)
                ).match() }
            )
        }
    }


    test("vcfexpress - prelude - vcf - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/vcf/test.vcf.gz', checkIfExists: true),
                ]

                input[1] = [file('${moduleDir}/tests/prelude_test.lua')]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(
                    sanitizeOutput(process.out)
                ).match() }
            )
        }
    }
}
