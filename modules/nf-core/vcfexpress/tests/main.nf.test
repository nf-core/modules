// TODO nf-core: Once you have added the required tests, please run the following command to build this file:
// nf-core modules test vcfexpress
nextflow_process {

    name "Test Process VCFEXPRESS"
    script "../main.nf"
    process "VCFEXPRESS"

    tag "modules"
    tag "modules_nfcore"
    tag "vcfexpress"

    config "./nextflow.config"


    test("vcfexpress - vcf") { 

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/vcf/test.vcf.gz', checkIfExists: true),
                ]

                input[1] = []
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(
                    sanitizeOutput(process.out)
                ).match() }
            )
        }

    }

    test("vcfexpress - vcf - prelude") {

        when { 
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/vcf/test.vcf.gz', checkIfExists: true),
                ]

                input[1] = [file('/home/sofia/work/pipelines/modules/modules/nf-core/vcfexpress/tests/prelude_test.lua')]
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(
                    sanitizeOutput(process.out)
                ).match() }
            )
        }

    }
