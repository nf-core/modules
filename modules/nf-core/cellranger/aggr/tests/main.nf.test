nextflow_process {

    name "Test Process CELLRANGER_AGGR"
    script "../main.nf"
    config "./nextflow.config"
    process "CELLRANGER_AGGR"

    tag "modules"
    tag "modules_nfcore"
    tag "cellranger"
    tag "cellranger/aggr"
    tag "cellranger/mkref"
    tag "cellranger/count"

    setup {
        config "./nextflow.config"

        run("CELLRANGER_MKREF") {
            script "../../mkref/main.nf"
            process {
                """
                input[0] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/10xgenomics/cellranger/sc3_v3_5k_a549_gex_crispr/reference/genome_chr1_32292083_32686211.fa', checkIfExists: true)
                input[1] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/10xgenomics/cellranger/sc3_v3_5k_a549_gex_crispr/reference/genes_chr1_32292083_32686211.gtf', checkIfExists: true)
                input[2] = "a549_chr1_reference"
                """
            }
        }

        run("CELLRANGER_COUNT") {
            script "../../count/main.nf"
            process {
                """
                input[0] = [
                    [ id:'a549_gex', single_end:false, strandedness:'auto' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/10xgenomics/cellranger/sc3_v3_5k_a549_gex_crispr/fastqs/gex/subsampled_SC3_v3_NextGem_DI_CRISPR_A549_5K_gex_S5_L001_R1_001.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/10xgenomics/cellranger/sc3_v3_5k_a549_gex_crispr/fastqs/gex/subsampled_SC3_v3_NextGem_DI_CRISPR_A549_5K_gex_S5_L001_R2_001.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/10xgenomics/cellranger/sc3_v3_5k_a549_gex_crispr/fastqs/gex/subsampled_SC3_v3_NextGem_DI_CRISPR_A549_5K_gex_S5_L002_R1_001.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/10xgenomics/cellranger/sc3_v3_5k_a549_gex_crispr/fastqs/gex/subsampled_SC3_v3_NextGem_DI_CRISPR_A549_5K_gex_S5_L002_R2_001.fastq.gz', checkIfExists: true)
                    ]
                ]
                input[1] = CELLRANGER_MKREF.out.reference
                """
            }
        }
    }

    test("A549 chr1 - aggr from count output") {
        config "./nextflow.config"

        when {
            process {
                """
                input[0] = CELLRANGER_COUNT.out.outs
                    .map { meta, files ->
                        def mol_info = files.find { it.name == 'molecule_info.h5' }
                        "\${meta.id},\${mol_info}"
                    }
                    .collectFile(
                        name:    'aggregation.csv',
                        newLine: true,
                        seed:    'sample_id,molecule_h5'
                    )
                    .map { csv -> [ [id: 'aggregation'], csv ] }
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out.versions).match() },
                { assert file(process.out.outs.get(0).get(1).find { file(it).name == 'web_summary.html' }).exists() },
                { assert file(process.out.outs.get(0).get(1).find { file(it).name == 'filtered_feature_bc_matrix.h5' }).exists() },
            )
        }
    }

    test("A549 chr1 - aggr from count output - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id: 'aggregation' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/10xgenomics/cellranger/sc3_v3_5k_a549_gex_crispr/reference/genes_chr1_32292083_32686211.gtf', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

}
