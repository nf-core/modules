nextflow_process {

    name "Test Process FLASH"
    script "../main.nf"
    process "FLASH"
    config "./nextflow.config"
    tag "modules"
    tag "modules_nfcore"
    tag "flash"

    test("sarscov2 - paired-end") {

        when {
            params{
                outdir = "test"
            }
            process {
                """
                input[0] = [
                    [ id: "test", single_end:false], // meta map
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.merged[0][1].endsWith(".extendedFrags.fastq.gz") },
                { assert process.out.notcombined[0][1][0].endsWith(".notCombined_1.fastq.gz") },
                { assert process.out.notcombined[0][1][1].endsWith(".notCombined_2.fastq.gz") },
                { assert snapshot(
                    process.out.histogram,
                    process.out.versions_flash
                ).match() },
                { assert snapshot(process.out.versions_flash).match("versions") }
            )
        }

    }

    test("sarscov2 - stub") {

        options "-stub"

        when {
            params{
                outdir = "test"
            }
            process {
                """
                input[0] = [
                    [ id: "test", single_end:false], // meta map
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }

    }

}
