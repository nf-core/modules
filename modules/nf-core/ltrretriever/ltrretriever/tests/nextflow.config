process {

    withName: LTRFINDER {
        ext.args = '-harvest_out'
        // LTRRETRIEVER_LTRRETRIEVER requires -harvest_out
    }

    withName: LTRHARVEST {
        ext.prefix = { "${meta.id}_ltrharvest" }
    }

    withName: FIND_CONCATENATE {
        ext.prefix = { "${meta.id}_ltrharvest_ltrfinder.tabout" }
    }
}
