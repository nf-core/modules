nextflow_process {

    name "Test Process TREERECS"
    script "../main.nf"
    process "TREERECS"

    tag "modules"
    tag "modules_nfcore"
    tag "treerecs"

    test("treerecs - polytomy example") {

        when {
            process {
                """              
                input[0] = [
                    [ id:'test' ],
                    file('https://gitlab.inria.fr/Phylophile/Treerecs/-/raw/master/examples/polytomy_example/speciesTree.txt?ref_type=heads', checkIfExists: true),
                    file('https://gitlab.inria.fr/Phylophile/Treerecs/-/raw/master/examples/polytomy_example/geneTree.txt?ref_type=heads', checkIfExists: true),
                ]
                """
            }
        }

        then {
            assert process.success
            assert process.out.corrected_trees.size() == 1
            assert process.out.corrected_trees[0][1].endsWith(".nwk")

            assert snapshot(
                process.out.findAll { key, val -> key.startsWith("versions") }
            ).match()
        }

    }

    test("streerecs - polytomy example - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file('https://gitlab.inria.fr/Phylophile/Treerecs/-/raw/master/examples/polytomy_example/speciesTree.txt?ref_type=heads', checkIfExists: true),
                    file('https://gitlab.inria.fr/Phylophile/Treerecs/-/raw/master/examples/polytomy_example/geneTree.txt?ref_type=heads', checkIfExists: true),
                ]
                """
            }
        }

        then {
            assert process.success
            assert process.out.corrected_trees.size() == 1
            assert process.out.corrected_trees[0][1].endsWith(".nwk")

            assert snapshot(
                process.out.findAll { key, val -> key.startsWith("versions") }
            ).match()
        }

    }

}
