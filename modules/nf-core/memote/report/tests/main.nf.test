nextflow_process {

    name "Test Process MEMOTE_REPORT"
    script "../main.nf"
    config "./nextflow.config"
    process "MEMOTE_REPORT"

    tag "modules"
    tag "modules_nfcore"
    tag "memote"
    tag "memote/report"

    test("candidatus_portiera - xml - html") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/prokaryotes/candidatus_portiera_aleyrodidarum/gapseq/test.xml', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.report.get(0).get(1) ==~ ".*/test.html" },
                {
                    with (path(process.out.versions.get(0)).yaml) {
                        assert MEMOTE_REPORT
                        assert MEMOTE_REPORT.memote
                    }
                }
            )
        }
    }

    test("candidatus_portiera - xml - html - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/prokaryotes/candidatus_portiera_aleyrodidarum/gapseq/test.xml', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.report.get(0).get(1) ==~ ".*/test.html" },
                {
                    with (path(process.out.versions.get(0)).yaml) {
                        assert MEMOTE_REPORT
                        assert MEMOTE_REPORT.memote
                    }
                }
            )
        }
    }
}
