nextflow_process {

    name "Test Process MEMOTE_RUN"
    script "../main.nf"
    config "./nextflow.config"
    process "MEMOTE_RUN"

    tag "modules"
    tag "modules_nfcore"
    tag "memote"
    tag "memote/run"

    test("candidatus_portiera - xml - json") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/prokaryotes/candidatus_portiera_aleyrodidarum/gapseq/test.xml', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys: ["json"])).match() }
            )
        }
    }

    test("candidatus_portiera - xml - json - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/prokaryotes/candidatus_portiera_aleyrodidarum/gapseq/test.xml', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    process.out.json
                ).match() }
            )
        }
    }
}
