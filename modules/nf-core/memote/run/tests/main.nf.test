nextflow_process {

    name "Test Process MEMOTE_RUN"
    script "../main.nf"
    config "./nextflow.config"
    process "MEMOTE_RUN"

    tag "modules"
    tag "modules_nfcore"
    tag "memote"
    tag "memote/run"

    test("run tests on tiny SBML model") {

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file('https://raw.githubusercontent.com/opencobra/memote/master/tests/test_for_support/data/validation/tiny_FBC.xml', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.json.get(0).get(1) ==~ ".*/test.json.gz" },
                {
                    with (path(process.out.versions.get(0)).yaml) {
                        assert MEMOTE_RUN
                        assert MEMOTE_RUN.memote
                    }
                }
            )
        }
    }

    test("run tests on tiny SBML model - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file('https://raw.githubusercontent.com/opencobra/memote/master/tests/test_for_support/data/validation/tiny_FBC.xml', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert sanitizeOutput(process.out).json.get(0).get(1) == "test.json.gz" },
                {
                    with (path(process.out.versions.get(0)).yaml) {
                        assert MEMOTE_RUN
                        assert MEMOTE_RUN.memote
                    }
                }
            )
        }
    }
}
