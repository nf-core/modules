nextflow_process {

    name "Test Process CLEANIFIER_INDEX"
    script "../main.nf"
    process "CLEANIFIER_INDEX"
    config "./nextflow.config"

    tag "modules"
    tag "modules_nfcore"
    tag "cleanifier"
    tag "cleanifier/index"

    test("sarscov2 - fasta - probabilistic") {

        when {
            params {
                module_args = '-k 31'
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true)
                ]
                input[1] = 100000
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert path(process.out.index[0][1]).exists() },
                { assert path(process.out.info[0][1]).exists() },
                { assert snapshot(
                    path(process.out.index[0][1]).getFileName().toString(),
                    path(process.out.info[0][1]).getFileName().toString(),
                    process.out.findAll { key, val -> key.startsWith("versions") }
                    ).match() 
                }
            )
        }
    }

    test("sarscov2 - fasta - exact") {

        when {
            params {
                module_args = '-k 31 --exact'
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true)
                ]
                input[1] = 100000
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert path(process.out.index[0][1]).exists() },
                { assert path(process.out.info[0][1]).exists() },
                { assert snapshot(
                    path(process.out.index[0][1]).getFileName().toString(),
                    path(process.out.info[0][1]).getFileName().toString(),
                    process.out.findAll { key, val -> key.startsWith("versions") }
                    ).match() 
                }
            )
        }
    }

    test("sarscov2 - fasta - stub") {

        options "-stub"

        when {
            params {
                module_args = '-k 31'
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true)
                ]
                input[1] = 100000
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
