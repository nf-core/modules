nextflow_process {

    name "Test Process MAPAD_MAP"
    tag "modules_nfcore"
    tag "modules"
    tag "mapad"
    tag "mapad/map"
    tag "mapad/index"
    script "../main.nf"
    process "MAPAD_MAP"

    test("Single-End") {

        setup {
            run("MAPAD_INDEX") {
                script "../../index/main.nf"
                process {
                    """
                    input[0] = [
                        [id: 'test'],
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true)
                    ]
                    """
                }
            }
        }

        when {
            process {
                """
                input[0] = [
                    [ id:'test', single_end:true ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.single_end.bam', checkIfExists: true)
                ]
                input[1] = MAPAD_INDEX.out.index
                input[2] = 0.03
                input[3] = false
                input[4] = 0.5
                input[5] = 0.5
                input[6] = 0.02
                input[7] = 1.0
                input[8] = 0.001
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["bam"])).match() }
            )
        }
    }

    test("Single-End -- stub") {
        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test', single_end:true ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.single_end.bam', checkIfExists: true)
                ]
                input[1] = [[], []]
                input[2] = 0.03
                input[3] = false
                input[4] = 0.5
                input[5] = 0.5
                input[6] = 0.02
                input[7] = 1.0
                input[8] = 0.001
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() }
            )
        }
    }
}
