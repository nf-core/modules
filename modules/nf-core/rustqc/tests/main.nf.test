nextflow_process {

    name "Test Process RUSTQC"
    script "../main.nf"
    process "RUSTQC"

    tag "modules"
    tag "modules_nfcore"
    tag "rustqc"

    test("sarscov2 paired-end [bam]") {

        when {
            process {
                """
                input[0] = channel.of([
                    [ id:'test', single_end:false, strandedness:'forward' ],
                    file(params.modules_testdata_base_path + "genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam.bai", checkIfExists: true)
                ])
                input[1] = channel.of([
                    [ id:'sarscov2' ],
                    file(params.modules_testdata_base_path + "genomics/sarscov2/genome/genome.gtf", checkIfExists: true)
                ])
                """
            }
        }

        then {
            assertAll(
                { assert process.success },

                // dupradar - existence only (plots and tables are not reproducible)
                { assert process.out.dupradar[0][1].any { it.toString().contains("dupMatrix") } },

                // featurecounts - content checks on reproducible tabular outputs
                { assert process.out.featurecounts[0][1].any { it.toString().endsWith(".featureCounts.tsv") } },
                { assert process.out.featurecounts[0][1].any { it.toString().contains("biotype_counts_mqc") } },

                // preseq - check lc_extrap has expected header
                { assert process.out.preseq[0][1].any { path(it).text.contains("TOTAL_READS") } },

                // samtools - existence only (content not reproducible across runs)
                { assert process.out.samtools[0][1].any { it.toString().contains("flagstat") } },
                { assert process.out.samtools[0][1].any { it.toString().contains("idxstats") } },
                { assert process.out.samtools[0][1].any { it.toString().contains("stats") } },

                // rseqc - content checks on reproducible text outputs
                { assert process.out.rseqc[0][1].any { it.toString().contains("infer_experiment") && path(it).text.contains("Fraction of reads") } },
                { assert process.out.rseqc[0][1].any { it.toString().contains("tin.xls") } },

                // qualimap - existence only (html and images not reproducible)
                { assert process.out.qualimap[0][1].any { it.toString().contains("qualimapReport") } }
            )
        }
    }

    test("sarscov2 single-end [bam]") {

        when {
            process {
                """
                input[0] = channel.of([
                    [ id:'test', single_end:true, strandedness:'forward' ],
                    file(params.modules_testdata_base_path + "genomics/sarscov2/illumina/bam/test.single_end.sorted.bam", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/sarscov2/illumina/bam/test.single_end.sorted.bam.bai", checkIfExists: true)
                ])
                input[1] = channel.of([
                    [ id:'sarscov2' ],
                    file(params.modules_testdata_base_path + "genomics/sarscov2/genome/genome.gtf", checkIfExists: true)
                ])
                """
            }
        }

        then {
            assertAll(
                { assert process.success },

                // featurecounts
                { assert process.out.featurecounts[0][1].any { it.toString().endsWith(".featureCounts.tsv") } },

                // preseq
                { assert process.out.preseq[0][1].any { path(it).text.contains("TOTAL_READS") } },

                // samtools
                { assert process.out.samtools[0][1].any { it.toString().contains("flagstat") } },

                // rseqc
                { assert process.out.rseqc[0][1].any { it.toString().contains("infer_experiment") && path(it).text.contains("Fraction of reads") } },

                // qualimap
                { assert process.out.qualimap[0][1].any { it.toString().contains("qualimapReport") } }
            )
        }
    }

    test("sarscov2 paired-end [bam] - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = channel.of([
                    [ id:'test', single_end:false, strandedness:'forward' ],
                    file(params.modules_testdata_base_path + "genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam.bai", checkIfExists: true)
                ])
                input[1] = channel.of([
                    [ id:'sarscov2' ],
                    file(params.modules_testdata_base_path + "genomics/sarscov2/genome/genome.gtf", checkIfExists: true)
                ])
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("sarscov2 single-end [bam] - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = channel.of([
                    [ id:'test', single_end:true, strandedness:'forward' ],
                    file(params.modules_testdata_base_path + "genomics/sarscov2/illumina/bam/test.single_end.sorted.bam", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/sarscov2/illumina/bam/test.single_end.sorted.bam.bai", checkIfExists: true)
                ])
                input[1] = channel.of([
                    [ id:'sarscov2' ],
                    file(params.modules_testdata_base_path + "genomics/sarscov2/genome/genome.gtf", checkIfExists: true)
                ])
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
