nextflow_process {

    name "Test Process RUSTQC"
    script "../main.nf"
    process "RUSTQC"

    tag "modules"
    tag "modules_nfcore"
    tag "rustqc"

    test("homo_sapiens paired-end [bam]") {

        config './nextflow.config'

        when {
            process {
                """
                input[0] = channel.of([
                    [ id:'test', single_end:false, strandedness:'forward' ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/illumina/bam/test.paired_end.sorted.bam", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/illumina/bam/test.paired_end.sorted.bam.bai", checkIfExists: true)
                ])
                input[1] = channel.of([
                    [ id:'homo_sapiens' ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/genome/genome.gtf", checkIfExists: true)
                ])
                """
            }
        }

        then {
            assertAll(
                { assert process.success },

                // featurecounts - validate content
                { assert process.out.featurecounts[0][1].any {
                    it.toString().endsWith(".featureCounts.tsv") &&
                    file(it).text.contains("Geneid") &&
                    file(it).text.contains("ENSG00000239435")
                } },
                { assert process.out.featurecounts[0][1].any { it.toString().contains("biotype_counts_mqc") } },

                // preseq - validate header
                { assert file(process.out.preseq[0][1]).text.contains("TOTAL_READS") },

                // samtools - validate read counts
                { assert process.out.samtools[0][1].any {
                    it.toString().endsWith(".flagstat") &&
                    file(it).text.contains("5644 + 0 in total")
                } },
                { assert process.out.samtools[0][1].any {
                    it.toString().endsWith(".idxstats") } },

                // rseqc - validate infer_experiment fractions
                { assert process.out.rseqc[0][1].any {
                    it.toString().endsWith("infer_experiment.txt") &&
                    file(it).text.contains("Fraction of reads explained by")
                } },
                // rseqc - tin exists
                { assert process.out.rseqc[0][1].any { it.toString().endsWith("tin.xls") } },

                // qualimap - validate aligned read count
                { assert process.out.qualimap[0][1].any {
                    it.toString().endsWith("rnaseq_qc_results.txt") &&
                    file(it).text.contains("total alignments = 5,642")
                } },

                // dupradar - existence
                { assert process.out.dupradar[0][1].any { it.toString().contains("dupMatrix") } }
            )
        }
    }

    test("homo_sapiens paired-end [bam] - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = channel.of([
                    [ id:'test', single_end:false, strandedness:'forward' ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/illumina/bam/test.paired_end.sorted.bam", checkIfExists: true),
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/illumina/bam/test.paired_end.sorted.bam.bai", checkIfExists: true)
                ])
                input[1] = channel.of([
                    [ id:'homo_sapiens' ],
                    file(params.modules_testdata_base_path + "genomics/homo_sapiens/genome/genome.gtf", checkIfExists: true)
                ])
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
