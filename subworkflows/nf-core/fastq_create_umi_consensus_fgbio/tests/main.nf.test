nextflow_workflow {

    name "Test Subworkflow FASTQ_CREATE_UMI_CONSENSUS_FGBIO"
    script "../main.nf"
    workflow "FASTQ_CREATE_UMI_CONSENSUS_FGBIO"

    tag "subworkflows"
    tag "subworkflows_nfcore"
    tag "subworkflows/fastq_create_umi_consensus_fgbio"
    tag "bwa/index"
    tag "bwa/mem"
    tag "bwamem2/mem"
    tag "bwamem2/index"
    tag "fgbio/callmolecularconsensusreads"
    tag "fgbio/callduplexconsensusreads"
    tag "fgbio/fastqtobam"
    tag "fgbio/filterconsensusreads"
    tag "fgbio/groupreadsbyumi"
    tag "fgbio/zipperbams"
    tag "samtools/fastq"
    tag "samtools/sort"
    tag "samtools/index"

    test("single_umi") {

        config './nextflow.config'
        when {
            params {
                fastqtobam_args        = "--read-structures +T 12M11S+T"
                fastqtobam_prefix      = "test_single_unaligned"
                bam2fastq_pre_args     = "-N"
                zipperbams_pre_args    = "--compression 1"
                zipperbams_pre_prefix  = "test_single_zipped"
                bamfilter_args         = "-f 1 --output-fmt bam"
                zipperbams_post_args   = "--compression 0"
                zipperbams_post_args2  = "--tags-to-reverse Consensus --tags-to-revcomp Consensus"
                zipperbams_post_prefix = "test_single_zipped"
            }
            workflow {
                """
                input[0] = Channel.value([
                    [ id:'test_single', single_end:false ], // meta map
                    [
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/fastq/test.umi_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/fastq/test.umi_2.fastq.gz', checkIfExists: true),
                    ]
                ])
                input[1] = Channel.value([
                    [ id:'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.fai', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.dict', checkIfExists: true)
                ])
                input[2] = false
                input[3] = "Adjacency"
                input[4] = "bwa-mem"
                input[5] = false
                input[6] = 1
                input[7] = 20
                input[8] = 0.5
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(sanitizeOutput(workflow.out)).match()
        }
    }

    test("duplex_umi") {

        config './nextflow.config'
        when {
            params {
                fastqtobam_args        = "--read-structures 38S2M1S+T 2M34S+T"
                fastqtobam_prefix      = "test_single_unaligned"
                bam2fastq_pre_args     = "-N"
                zipperbams_pre_args    = "--compression 1"
                zipperbams_pre_prefix  = "test_single_zipped"
                bamfilter_args         = "-f 1 --output-fmt bam"
                zipperbams_post_args   = "--compression 0"
                zipperbams_post_args2  = "--tags-to-reverse Consensus --tags-to-revcomp Consensus"
                zipperbams_post_prefix = "test_single_zipped"
            }
            workflow {
                """
                input[0] = Channel.value([
                    [ id:'test_single', single_end:false ], // meta map
                    [
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/fastq/test_duplex_umi_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/fastq/test_duplex_umi_2.fastq.gz', checkIfExists: true),
                    ]
                ])
                input[1] = Channel.value([
                    [ id:'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.fai', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.dict', checkIfExists: true)
                ])
                input[2] = false
                input[3] = "Adjacency"
                input[4] = "bwa-mem"
                input[5] = false
                input[6] = 1
                input[7] = 20
                input[8] = 0.5
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(sanitizeOutput(workflow.out)).match()
        }
    }

    test("single_umi - stub") {

        options "-stub"
        config './nextflow.config'
        when {
            params {
                fastqtobam_args        = "--read-structures +T 12M11S+T"
                fastqtobam_prefix      = "test_single_unaligned"
                bam2fastq_pre_args     = "-N"
                zipperbams_pre_args    = "--compression 1"
                zipperbams_pre_prefix  = "test_single_zipped"
                bamfilter_args         = "-f 1 --output-fmt bam"
                zipperbams_post_args   = "--compression 0"
                zipperbams_post_args2  = "--tags-to-reverse Consensus --tags-to-revcomp Consensus"
                zipperbams_post_prefix = "test_single_zipped"
            }
            workflow {
                """
                input[0] = Channel.value([
                    [ id:'test_single', single_end:false ], // meta map
                    [
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/fastq/test.umi_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/fastq/test.umi_2.fastq.gz', checkIfExists: true),
                    ]
                ])
                input[1] = Channel.value([
                    [ id:'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.fai', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.dict', checkIfExists: true)
                ])
                input[2] = false
                input[3] = "Adjacency"
                input[4] = "bwa-mem"
                input[5] = false
                input[6] = 1
                input[7] = 20
                input[8] = 0.5
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success},
                { assert snapshot(sanitizeOutput(workflow.out)).match()}
            )
        }
    }
}
