nextflow_workflow {

    name "Test Subworkflow GTF_BUILDHYBRIDANNOTATION_GFFCOMPARE"
    script "../main.nf"
    config "../nextflow.config"

    workflow "GTF_BUILDHYBRIDANNOTATION_GFFCOMPARE"

    tag "subworkflows"
    tag "subworkflows_nfcore"
    tag "subworkflows/gtf_buildhybridannotation_gffcompare"

    tag "gffcompare"
    tag "gawk"
    tag "bedtools"
    tag "bedtools/intersect"

    test("chr21 reference + chr22 novel - no blacklist") {

        when {
            workflow {
                """
                input[0] = Channel.of([
                    [id: 'chr22_novel'],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.gtf', checkIfExists: true)
                ])
                input[1] = Channel.value([
                    [id: 'chr21_reference'],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/chr21/sequence/chr21_gencode.gtf', checkIfExists: true)
                ])
                input[2] = Channel.value([
                    [id: 'chr21_backbone'],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/chr21/sequence/chr21_gencode.gtf', checkIfExists: true)
                ])
                input[3] = Channel.value("u,j,i,k,m,n,o,p,r,s,x,y,=")
                input[4] = Channel.empty()
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert workflow.out.hybrid_gtf.size() == 1 },
                { assert snapshot(
                    workflow.out.hybrid_gtf,
                    workflow.out.gffcompare_tracking,
                    workflow.out.gffcompare_loci
                ).match() }
            )
        }
    }

    test("chr21 reference + chr22 novel - with chr22 blacklist") {

        when {
            workflow {
                """
                input[0] = Channel.of([
                    [id: 'chr22_novel'],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.gtf', checkIfExists: true)
                ])
                input[1] = Channel.value([
                    [id: 'chr21_reference'],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/chr21/sequence/chr21_gencode.gtf', checkIfExists: true)
                ])
                input[2] = Channel.value([
                    [id: 'chr21_backbone'],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/chr21/sequence/chr21_gencode.gtf', checkIfExists: true)
                ])
                input[3] = Channel.value("u,j,i,k,m,n,o,p,r,s,x,y,=")
                input[4] = Channel.of([
                    [id: 'chr22_blacklist'],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.blacklist_intervals.bed', checkIfExists: true)
                ])
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert workflow.out.hybrid_gtf.size() == 1 },
                { assert snapshot(
                    workflow.out.hybrid_gtf,
                    workflow.out.gffcompare_tracking,
                    workflow.out.gffcompare_loci
                ).match() }
            )
        }
    }
}
