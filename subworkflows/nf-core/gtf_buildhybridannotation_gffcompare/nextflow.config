/*
 * IMPORTANT: This config file should be included by consumer pipelines (via
 * `includeConfig`) or passed with `-c` for standalone runs; it carries the
 * GAWK programs that GAWK_FILTER and GAWK_CONCAT need to drop class-code
 * mismatches and to merge a backbone GTF with novel transcripts.
 */
process {

    withName: 'GTF_BUILDHYBRIDANNOTATION_GFFCOMPARE:GAWK_FILTER' {
        ext.args   = { "-v codes_csv='${meta.class_codes}'" }
        ext.args2  = '\'BEGIN { n = split(codes_csv, arr, /,[[:space:]]*/); for (i = 1; i <= n; i++) keep_code[arr[i]] = 1 } /^#/ { next } $7 == "." { next } { if (match($0, /transcript_id "([^"]+)"/, t)) { if (match($0, /class_code "([^"]+)"/, c)) { if (c[1] in keep_code) keep_tx[t[1]] = 1 } if (t[1] in keep_tx) print $0 } }\''
        ext.prefix = { "${meta.id}_filtered" }
        ext.suffix = 'gtf'
    }

    withName: 'GTF_BUILDHYBRIDANNOTATION_GFFCOMPARE:BEDTOOLS_INTERSECT' {
        ext.prefix = { "${meta.id}_blacklisted" }
        ext.suffix = 'gtf'
    }

    withName: 'GTF_BUILDHYBRIDANNOTATION_GFFCOMPARE:GAWK_CONCAT' {
        ext.args2  = '\'BEGIN { FS="\\t"; OFS="\\t" } /^#/ { next } $3 == "gene" { if (match($9, /gene_id "([^"]+)"/, m)) gene_seen[m[1]] = 1; print; next } $3 == "transcript" { if (match($9, /gene_id "([^"]+)"/, m)) { gid = m[1]; if (!(gid in gene_seen) && !(gid in synth)) { print $1, $2, "gene", $4, $5, ".", $7, ".", "gene_id \"" gid "\";"; synth[gid] = 1 } } print; next } { print }\''
        ext.prefix = { "${meta.id}_hybrid" }
        ext.suffix = 'gtf'
    }
}
