nextflow_workflow {

    name "Test Workflow BAM_APPLYBQSR"
    script "../main.nf"
    workflow "BAM_APPLYBQSR"
    config "./nextflow.config"

    tag "subworkflows"
    tag "subworkflows_nfcore"
    tag "bam_applybqsr"
    tag "subworkflows/bam_applybqsr"
    tag "gatk4/applybqsr"
    tag "samtools/merge"

    test("homo_sapiens - cram - with intervals") {

        when {
            params {
                samtools_args = '--write-index'
            }
            workflow {
                """
                input[0] = channel.of([
                    [ id:'test', single_end:false ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/cram/test.paired_end.sorted.cram', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/cram/test.paired_end.sorted.cram.crai', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/gatk/test.baserecalibrator.table', checkIfExists: true)
                ])
                input[1] = channel.value([
                    [ id:'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.fai', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.dict', checkIfExists: true)
                ])
                input[2] = channel.of(
                    [file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.intervals1_multi.bed', checkIfExists: true), 2],
                    [file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.intervals2_multi.bed', checkIfExists: true), 2]
                )
                input[3] = 'cram'
                """
                }
            }

        then {
            def fasta_base = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/'
            def fasta = fasta_base + 'genomics/homo_sapiens/genome/genome.fasta'
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.out.recal_out.collect { meta, reads, index ->
                        [ file(reads).name + ':readsMD5,' + cram(reads, fasta).getReadsMD5(), file(index).name]
                    }
                ).match()}
            )
        }
    }

    test("homo_sapiens - cram") {

        when {
            params {
                samtools_args = '--write-index'
            }
            workflow {
                """
                input[0] = channel.of([
                    [ id:'test', single_end:false ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/cram/test.paired_end.sorted.cram', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/cram/test.paired_end.sorted.cram.crai', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/gatk/test.baserecalibrator.table', checkIfExists: true)
                ])
                input[1] = channel.value([
                    [ id:'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.fai', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.dict', checkIfExists: true)
                ])
                input[2] = channel.of([[], 0])
                input[3] = 'cram'
                """
                }
            }

        then {
            def fasta_base = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/'
            def fasta = fasta_base + 'genomics/homo_sapiens/genome/genome.fasta'
