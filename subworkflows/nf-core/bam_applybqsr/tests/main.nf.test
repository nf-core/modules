nextflow_workflow {

    name "Test Workflow BAM_APPLYBQSR"
    script "../main.nf"
    workflow "BAM_APPLYBQSR"

    tag "subworkflows"
    tag "subworkflows_nfcore"
    tag "bam_applybqsr"
    tag "subworkflows/bam_applybqsr"
    tag "gatk4/applybqsr"

    test("homo_sapiens - cram - with intervals") {

        when {
            workflow {
                """
                input[0] = Channel.of([
                    [ id:'test', single_end:false ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/cram/test.paired_end.sorted.cram', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/cram/test.paired_end.sorted.cram.crai', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/gatk/test.baserecalibrator.table', checkIfExists: true)
                ])
                input[1] = Channel.of([
                    [ id:'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true)
                ])
                input[2] = Channel.of([
                    [ id:'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.fai', checkIfExists: true)
                ])
                input[3] = Channel.of([
                    [ id:'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.dict', checkIfExists: true)
                ])
                def multiIntervalsFile = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.multi_intervals.bed')
                def lines = multiIntervalsFile.readLines()
                def outputDir = new File(workflow.workDir, 'intervals')
                outputDir.mkdirs()
                def interval1File = new File(outputDir, 'interval1.bed')
                interval1File.text = lines[0]
                def interval2File = new File(outputDir, 'interval2.bed')
                interval2File.text = lines[1]
                input[4] = Channel.of(
                    [interval1File, 2],
                    [interval2File, 2]
                )
                """
            }
        }
   then {
        assertAll(
                { assert workflow.success },
                { assert snapshot(sanitizeOutput(workflow.out)).match() }
            )
        }
    }

    test("homo_sapiens - cram - with intervals - stub") {

        options "-stub-run"

        when {
            workflow {
                """
                input[0] = Channel.of([
                    [ id:'test', single_end:false ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/cram/test.paired_end.sorted.cram', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/cram/test.paired_end.sorted.cram.crai', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/gatk/test.baserecalibrator.table', checkIfExists: true)
                ])
                input[1] = Channel.of([
                    [ id:'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true)
                ])
                input[2] = Channel.of([
                    [ id:'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.fai', checkIfExists: true)
                ])
                input[3] = Channel.of([
                    [ id:'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.dict', checkIfExists: true)
                ])
                def multiIntervalsFile = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.multi_intervals.bed')
                def lines = multiIntervalsFile.readLines()
                def outputDir = new File(workflow.workDir, 'intervals')
                outputDir.mkdirs()
                def interval1File = new File(outputDir, 'interval1.bed')
                interval1File.text = lines[0]
                def interval2File = new File(outputDir, 'interval2.bed')
                interval2File.text = lines[1]
                input[4] = Channel.of(
                    [interval1File, 2],
                    [interval2File, 2]
                )
                """
            }
        }
   then {
        assertAll(
                { assert workflow.success },
                { assert snapshot(sanitizeOutput(workflow.out)).match() }
            )
        }
    }

}
