/*
 * IMPORTANT: This config file should be included by consumer pipelines (via
 * `includeConfig`) or passed with `-c` for standalone runs; it carries the
 * GAWK programs that GAWK_FILTER and GAWK_CONCAT need to drop class-code
 * mismatches and to merge a backbone GTF with novel transcripts.
 *
 * Resource sizing: GAWK steps hold the full input in memory under
 * `process_single`. Fine for annotation-scale GTFs; for >~500 MB inputs
 * override `memory` / `cpus` directly via `withName`.
 *
 * Annotation format: both awks assume standard GTF2 with `gene_id` and
 * `transcript_id` attributes in column 9 and `gene` / `transcript` in column 3.
 * GFF3 inputs (Parent= / ID= attributes), prokaryotic GTFs without transcript
 * rows, and any other dialect are out of scope.
 */
process {

    /*
     * GAWK_FILTER - class-code subsetter.
     *
     * Reads a gffcompare `*.annotated.gtf` (transcript rows with a `class_code`
     * attribute, plus exon/CDS/UTR children that share `transcript_id`), keeps
     * only the records belonging to transcripts whose class_code is in the
     * caller-supplied set, and emits the survivors in their original order.
     *
     * Algorithm (one pass over the input, plus an END pass over a buffer):
     *
     *   BEGIN
     *     parse `codes_csv` (passed in via `-v` from the closure-form
     *     `ext.args`) into a `keep_code[]` hash for O(1) lookup
     *
     *   FOR EACH INPUT RECORD
     *     skip comment lines (`/^#/`)
     *     skip dot-strand rows (`$7 == "."`) - gffcompare emits these for
     *       ambiguous transcripts; they have no useful class assignment
     *     extract `transcript_id` from column 9 (records that don't carry one
     *       are dropped silently - gffcompare's annotated.gtf only contains
     *       transcript / exon / CDS / UTR rows, all of which carry it)
     *     if the line also carries `class_code "X";` and X is in keep_code,
     *       mark `keep_tx[tid] = 1`
     *     buffer the line (`lines[NR] = $0`) and its tid (`line_tid[NR] = tid`)
     *
     *   END
     *     iterate the buffer in numeric-index order (PROCINFO trick) so the
     *     output preserves input order; emit each line whose tid is in keep_tx
     *
     * The buffer-then-emit shape removes the otherwise-fragile assumption that
     * gffcompare emits each transcript row before its children: if a future
     * release reorders, a single-pass print-as-you-see implementation would
     * drop exons silently. Here, every record waits for the END pass after the
     * full set of kept transcript_ids is known.
     */
    withName: 'GTF_HYBRIDMERGE_GFFCOMPARE:GAWK_FILTER' {
        ext.args   = { "-v codes_csv='${meta.class_codes}'" }
        ext.args2  = '\'BEGIN { n = split(codes_csv, arr, /,[[:space:]]*/); for (i = 1; i <= n; i++) keep_code[arr[i]] = 1 } /^#/ { next } $7 == "." { next } { if (match($0, /transcript_id "([^"]+)"/, t)) { tid = t[1]; if (match($0, /class_code "([^"]+)"/, c)) { if (c[1] in keep_code) keep_tx[tid] = 1 } lines[NR] = $0; line_tid[NR] = tid } } END { PROCINFO["sorted_in"] = "@ind_num_asc"; for (i in lines) { if (line_tid[i] in keep_tx) print lines[i] } }\''
        ext.prefix = { "${meta.id}_filtered" }
        ext.suffix = 'gtf'
    }

    /*
     * BEDTOOLS_INTERSECT - blacklist subtraction.
     *
     * `-v` reports every interval in -a (the filtered novel GTF) that does NOT
     * overlap any interval in -b (the blacklist BED). Default position because
     * "blacklist" everywhere else in bioinformatics implies subtraction.
     * Consumers can override (`ext.args = '-v -s'` for strand-aware, or
     * `ext.args = ''` for positive overlap) in their own modules.config.
     */
    withName: 'GTF_HYBRIDMERGE_GFFCOMPARE:BEDTOOLS_INTERSECT' {
        ext.args   = '-v'
        ext.prefix = { "${meta.id}_blacklisted" }
        ext.suffix = 'gtf'
    }

    /*
     * GAWK_CONCAT - backbone + novel merge with synthesised gene rows.
     *
     * Reads two files (canonical backbone first, then filtered novel) and
     * produces a single hybrid GTF. The backbone arrives with proper
     * gene/transcript/exon structure; the novel input is gffcompare's output
     * downstream of GAWK_FILTER, so it only has transcript/exon/CDS rows -
     * gffcompare strips parent gene rows. Each surviving novel gene_id
     * therefore needs a synthesised `gene` row inserted into the output, with
     * coordinates spanning the union of all child transcripts.
     *
     * Algorithm (one pass over both files, plus an END pass over the buffer):
     *
     *   BEGIN
     *     set FS and OFS to tab so column splits work on real GTF data
     *
     *   FOR EACH INPUT RECORD
     *     skip comment lines (`/^#/`)
     *     if a `gene` row, record `gene_seen[gid] = 1` so we don't synth a
     *       duplicate later; gene rows from the backbone get propagated
     *       through the buffer as-is
     *     if a `transcript` row AND gid is not already in gene_seen (i.e.
     *       this is a novel transcript that needs a synthesised parent):
     *         min_start[gid] = min(min_start[gid], $4)
     *         max_end[gid]   = max(max_end[gid],   $5)
     *         (also stash chromosome / source / strand from the first sighting
     *          to use when we emit the synth row)
     *     always buffer the line (`lines[++nlines] = $0`)
     *
     *   END
     *     iterate the buffer in numeric-index order:
     *       split the line; if it's a transcript row for a gene_id that has
     *         not been seen in any gene row AND we haven't yet synthesised
     *         one, emit the synth row (using the per-gid union coords) BEFORE
     *         emitting the transcript line
     *       always emit the line itself
     *     the synth set is tracked in `synth[]` so each missing-from-backbone
     *     gene_id only gets one parent row, regardless of how many child
     *     transcripts it has.
     *
     * Why union spans: GTF readers that take gene-row coords at face value
     * (genome browsers, custom span filters) would otherwise see the gene
     * limited to the first novel transcript's footprint instead of the full
     * locus. Tools that ignore gene-row coords and re-derive from children
     * (STAR, Salmon, featureCounts, gffread) are unaffected either way.
     */
    withName: 'GTF_HYBRIDMERGE_GFFCOMPARE:GAWK_CONCAT' {
        ext.args2  = '\'BEGIN { FS="\\t"; OFS="\\t" } /^#/ { next } $3 == "gene" { if (match($9, /gene_id "([^"]+)"/, m)) gene_seen[m[1]] = 1 } $3 == "transcript" { if (match($9, /gene_id "([^"]+)"/, m)) { gid = m[1]; if (!(gid in gene_seen)) { if (!(gid in min_start) || $4 < min_start[gid]) min_start[gid] = $4; if (!(gid in max_end) || $5 > max_end[gid]) max_end[gid] = $5; if (!(gid in tx_chr)) { tx_chr[gid] = $1; tx_src[gid] = $2; tx_strand[gid] = $7 } } } } { lines[++nlines] = $0 } END { PROCINFO["sorted_in"] = "@ind_num_asc"; for (i in lines) { line = lines[i]; n = split(line, f, "\\t"); if (n >= 8 && f[3] == "transcript" && match(line, /gene_id "([^"]+)"/, m)) { gid = m[1]; if (!(gid in gene_seen) && !(gid in synth)) { print tx_chr[gid], tx_src[gid], "gene", min_start[gid], max_end[gid], ".", tx_strand[gid], ".", "gene_id \\"" gid "\\";"; synth[gid] = 1 } } print line } }\''
        ext.prefix = { "${meta.id}_hybrid" }
        ext.suffix = 'gtf'
    }
}
