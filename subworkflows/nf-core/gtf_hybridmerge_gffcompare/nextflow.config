/*
 * IMPORTANT: This config file should be included by consumer pipelines (via
 * `includeConfig`) or passed with `-c` for standalone runs; it carries the
 * GAWK programs that GAWK_FILTER and GAWK_CONCAT need to drop class-code
 * mismatches and to merge a backbone GTF with novel transcripts.
 */
process {

    // GAWK_FILTER: buffer-then-emit so the order of transcript vs exon rows
    // in the input doesn't matter. Pass over the input records which
    // transcript_ids pass the class-code filter; the END block prints
    // survivors in original input order.
    withName: 'GTF_HYBRIDMERGE_GFFCOMPARE:GAWK_FILTER' {
        ext.args   = { "-v codes_csv='${meta.class_codes}'" }
        ext.args2  = '\'BEGIN { n = split(codes_csv, arr, /,[[:space:]]*/); for (i = 1; i <= n; i++) keep_code[arr[i]] = 1 } /^#/ { next } $7 == "." { next } { if (match($0, /transcript_id "([^"]+)"/, t)) { tid = t[1]; if (match($0, /class_code "([^"]+)"/, c)) { if (c[1] in keep_code) keep_tx[tid] = 1 } lines[NR] = $0; line_tid[NR] = tid } } END { PROCINFO["sorted_in"] = "@ind_num_asc"; for (i in lines) { if (line_tid[i] in keep_tx) print lines[i] } }\''
        ext.prefix = { "${meta.id}_filtered" }
        ext.suffix = 'gtf'
    }

    withName: 'GTF_HYBRIDMERGE_GFFCOMPARE:BEDTOOLS_INTERSECT' {
        ext.args   = '-v'
        ext.prefix = { "${meta.id}_blacklisted" }
        ext.suffix = 'gtf'
    }

    // GAWK_CONCAT: buffer-then-emit. Pass 1 (the per-line block) walks all
    // input rows, marks which gene_ids already have a gene row in the
    // backbone (`gene_seen`), and tracks the union span (min start, max end)
    // of every novel transcript per gene_id. END iterates the buffered lines
    // in original order and, immediately before the first transcript of any
    // novel gene_id, emits a synthesised gene row whose coords span the full
    // novel set (not just the first transcript's coords).
    withName: 'GTF_HYBRIDMERGE_GFFCOMPARE:GAWK_CONCAT' {
        ext.args2  = '\'BEGIN { FS="\\t"; OFS="\\t" } /^#/ { next } $3 == "gene" { if (match($9, /gene_id "([^"]+)"/, m)) gene_seen[m[1]] = 1 } $3 == "transcript" { if (match($9, /gene_id "([^"]+)"/, m)) { gid = m[1]; if (!(gid in gene_seen)) { if (!(gid in min_start) || $4 < min_start[gid]) min_start[gid] = $4; if (!(gid in max_end) || $5 > max_end[gid]) max_end[gid] = $5; if (!(gid in tx_chr)) { tx_chr[gid] = $1; tx_src[gid] = $2; tx_strand[gid] = $7 } } } } { lines[++nlines] = $0 } END { PROCINFO["sorted_in"] = "@ind_num_asc"; for (i in lines) { line = lines[i]; n = split(line, f, "\\t"); if (n >= 8 && f[3] == "transcript" && match(line, /gene_id "([^"]+)"/, m)) { gid = m[1]; if (!(gid in gene_seen) && !(gid in synth)) { print tx_chr[gid], tx_src[gid], "gene", min_start[gid], max_end[gid], ".", tx_strand[gid], ".", "gene_id \\"" gid "\\";"; synth[gid] = 1 } } print line } }\''
        ext.prefix = { "${meta.id}_hybrid" }
        ext.suffix = 'gtf'
    }
}
