params {
    npcs = 8
    use_approx = true
    algorithm = "kmeans"
    n_clusters = 3
    dbscan_eps = 0.5
    dbscan_min_samples = 5
}

process {
    withName: 'BEAGLE5_BEAGLE' {        
        ext.when = false
    }

    withName: 'PLINK2_VCF' {        
        ext.when = false
    }

    withName: 'PLINK2_PCA' {        
        ext.when = false
    }

    withName: 'CUSTOM_PCACLUSTERING' {        
        ext.when = false
    }

    withName: 'CUSTOM_CLUSTERMETRICS' {        
        ext.when = false
    }

    withName: 'CUSTOM_CLUSTERVISUALIZATION' {        
        ext.when = false
    }
}
